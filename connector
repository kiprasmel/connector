#!/bin/bash
# connector - headscale/tailscale mesh management tool
set -euo pipefail

VERSION="2.0.0"

# --- Constants ---------------------------------------------------------------
HEADSCALE_USER="mesh"
HEADSCALE_CONFIG="/etc/headscale/config.yaml"
HEADSCALE_ACL="/etc/headscale/acl.hujson"
HEADSCALE_LIB="/var/lib/headscale"
HEADSCALE_BIN="/usr/local/bin/headscale"
CONNECTOR_BIN="/usr/local/bin/connector"
STATE_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/connector"
CNC_LINK_FILE="${STATE_DIR}/cnc"
ROLE_FILE="${STATE_DIR}/role"
ALIASES_FILE="${STATE_DIR}/aliases.conf"
SSH_CONFIG_FILE="${HOME}/.ssh/config"
KEY_EXPIRY="${CONNECTOR_KEY_EXPIRY:-1h}"
WSL_MTU="1280"
TS_INSTALL_URL="https://tailscale.com/install.sh"

RESERVED_COMMANDS=(
    cnc-init link invite commander-key register approve list revoke
    status whoami hop alias cleanup cleanup-cnc help --help -h
)

# --- Logging -----------------------------------------------------------------
log_info()    { echo "[INFO] $*"; }
log_success() { echo "[OK] $*"; }
log_warn()    { echo "[WARN] $*"; }
log_error()   { echo "[ERROR] $*" >&2; }
die()         { log_error "$*"; exit 1; }

# --- Small helpers -----------------------------------------------------------
have() { command -v "$1" >/dev/null 2>&1; }

confirm() {
    # confirm "question" [y]  -> returns 0 on yes; ASSUME_YES=1 auto-confirms
    local prompt="$1" default="${2:-n}" reply
    [ "${ASSUME_YES:-0}" = "1" ] && return 0
    if [ "$default" = "y" ]; then
        read -r -p "$prompt [Y/n]: " reply || true
        reply="${reply:-y}"
    else
        read -r -p "$prompt [y/N]: " reply || true
        reply="${reply:-n}"
    fi
    [[ "$reply" =~ ^[Yy]$ ]]
}

require_root() {
    [ "$(id -u)" -eq 0 ] || die "This command must be run as root (try: sudo connector $*)"
}

# Run a command as root locally (no-op prefix when already root).
as_root() {
    if [ "$(id -u)" -eq 0 ]; then "$@"; else sudo "$@"; fi
}

# Resolve the absolute path of this script, following symlinks.
self_path() {
    local s="${BASH_SOURCE[0]}" d
    while [ -h "$s" ]; do
        d=$(cd -P "$(dirname "$s")" >/dev/null 2>&1 && pwd)
        s=$(readlink "$s")
        case "$s" in /*) ;; *) s="$d/$s" ;; esac
    done
    d=$(cd -P "$(dirname "$s")" >/dev/null 2>&1 && pwd)
    printf '%s/%s\n' "$d" "$(basename "$s")"
}

# Extract a top-level JSON string field ("field":"value") from stdin.
json_str() {
    sed -n 's/.*"'"$1"'":[[:space:]]*"\([^"]*\)".*/\1/p' | head -n1
}

# --- Role detection ----------------------------------------------------------
is_cnc()        { have headscale && [ -f "$HEADSCALE_CONFIG" ]; }
is_controller() { [ -f "$CNC_LINK_FILE" ]; }
is_admin()      { is_cnc || is_controller; }

node_role()   { [ -f "$ROLE_FILE" ] && cat "$ROLE_FILE" 2>/dev/null || true; }
is_provider() { case "$(node_role)" in provider|both) return 0 ;; *) return 1 ;; esac; }
is_consumer() { case "$(node_role)" in consumer|both) return 0 ;; *) return 1 ;; esac; }
is_node()     { have tailscale && tailscale status >/dev/null 2>&1; }

current_roles() {
    local roles=()
    is_cnc        && roles+=("cnc")
    is_controller && roles+=("controller")
    is_provider   && roles+=("provider")
    is_consumer   && roles+=("consumer")
    if [ "${#roles[@]}" -eq 0 ]; then
        if is_node; then roles+=("node (untagged)"); else roles+=("unconfigured"); fi
    fi
    echo "${roles[*]}"
}

# --- CNC link state ----------------------------------------------------------
CNC_SSH=""; CNC_URL=""; CNC_PORT=""; CNC_USER=""

load_cnc_link() {
    [ -f "$CNC_LINK_FILE" ] || die "No CNC linked. Run: connector link <user@host> --url https://..."
    # shellcheck disable=SC1090
    . "$CNC_LINK_FILE"
    CNC_USER="${CNC_SSH%@*}"
    [ "$CNC_USER" = "$CNC_SSH" ] && CNC_USER="$(id -un)"
}

save_cnc_link() {
    local ssh_target="$1" url="$2" port="${3:-}"
    mkdir -p "$STATE_DIR"; chmod 700 "$STATE_DIR" 2>/dev/null || true
    {
        echo "CNC_SSH=\"$ssh_target\""
        echo "CNC_URL=\"$url\""
        echo "CNC_PORT=\"$port\""
    } > "$CNC_LINK_FILE"
    chmod 600 "$CNC_LINK_FILE"
}

_ssh_port_flag() { [ -n "${CNC_PORT:-}" ] && printf -- '-p %s' "$CNC_PORT" || true; }
_scp_port_flag() { [ -n "${CNC_PORT:-}" ] && printf -- '-P %s' "$CNC_PORT" || true; }

# Run an arbitrary command on the CNC over SSH (as the linked admin user).
ssh_cnc() {
    load_cnc_link
    # shellcheck disable=SC2046,SC2086
    ssh -o ConnectTimeout=10 $(_ssh_port_flag) "$CNC_SSH" "$@"
}

# Run a headscale command against the CNC: locally if we are it, else over SSH.
hs() {
    if is_cnc; then
        as_root headscale "$@"
    elif is_controller; then
        load_cnc_link
        if [ "$CNC_USER" = "root" ]; then
            ssh_cnc headscale "$@"
        else
            ssh_cnc sudo headscale "$@"
        fi
    else
        die "Not a CNC and no CNC linked. Run 'connector cnc-init <host> --url ...' or 'connector link <host> --url ...'."
    fi
}

# Print the CNC's server_url (from local config or the saved link).
cnc_server_url() {
    if is_cnc; then
        sed -n 's/^server_url:[[:space:]]*//p' "$HEADSCALE_CONFIG" 2>/dev/null | head -n1
    elif is_controller; then
        load_cnc_link; printf '%s\n' "$CNC_URL"
    fi
}

# Resolve a node name (or numeric id) to a headscale node id.
resolve_node_id() {
    local node="$1" out id
    case "$node" in
        ''|*[!0-9]*) ;;                 # not purely numeric -> look up by name
        *) printf '%s\n' "$node"; return 0 ;;
    esac
    out="$(hs nodes list --output json 2>/dev/null)" || return 1
    id="$(printf '%s' "$out" | tr '{}' '\n\n' \
         | grep -E "\"(name|given_name)\":\"$node\"" | head -n1 \
         | sed -n 's/.*"id":[[:space:]]*"\{0,1\}\([0-9]\+\).*/\1/p')"
    [ -n "$id" ] && printf '%s\n' "$id"
}

# --- CNC: install + configure headscale -------------------------------------
detect_arch() {
    case "$(uname -m)" in
        x86_64|amd64)  echo "amd64" ;;
        aarch64|arm64) echo "arm64" ;;
        armv7l|armv6l) echo "arm" ;;
        *) die "Unsupported architecture: $(uname -m)" ;;
    esac
}

install_headscale() {
    if have headscale; then
        log_info "headscale already installed"
        return 0
    fi
    local ver="${HEADSCALE_VERSION:-}"
    if [ -z "$ver" ]; then
        log_info "Resolving latest headscale release..."
        ver="$(curl -fsSL https://api.github.com/repos/juanfont/headscale/releases/latest | json_str tag_name)"
    fi
    [ -n "$ver" ] || die "Could not determine headscale version (set HEADSCALE_VERSION=vX.Y.Z)"
    local arch num tmp
    arch="$(detect_arch)"; num="${ver#v}"; tmp="$(mktemp -d)"
    if have apt-get; then
        log_info "Installing headscale ${ver} (.deb, ${arch})..."
        curl -fsSL -o "$tmp/headscale.deb" \
            "https://github.com/juanfont/headscale/releases/download/${ver}/headscale_${num}_linux_${arch}.deb"
        as_root apt-get update -y
        as_root apt-get install -y "$tmp/headscale.deb"
    else
        log_info "Installing headscale ${ver} (binary, ${arch})..."
        curl -fsSL -o "$tmp/headscale" \
            "https://github.com/juanfont/headscale/releases/download/${ver}/headscale_${num}_linux_${arch}"
        as_root install -m 0755 "$tmp/headscale" "$HEADSCALE_BIN"
        install_headscale_service
    fi
    rm -rf "$tmp"
}

install_headscale_service() {
    log_info "Creating headscale systemd unit..."
    as_root mkdir -p "$HEADSCALE_LIB" /etc/headscale
    as_root tee /etc/systemd/system/headscale.service >/dev/null <<EOF
[Unit]
Description=headscale controller
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=${HEADSCALE_BIN} serve
Restart=always
RestartSec=5
WorkingDirectory=${HEADSCALE_LIB}
RuntimeDirectory=headscale
StateDirectory=headscale

[Install]
WantedBy=multi-user.target
EOF
    as_root systemctl daemon-reload
}

write_headscale_config() {
    local url="$1" base_domain="$2" host scheme listen_addr tls_block
    host="${url#*://}"; host="${host%%/*}"; host="${host%%:*}"
    scheme="${url%%://*}"
    if [ "$scheme" = "https" ]; then
        listen_addr="0.0.0.0:443"
        tls_block=$(printf 'tls_letsencrypt_hostname: "%s"\ntls_letsencrypt_cache_dir: %s/cache\ntls_letsencrypt_challenge_type: TLS-ALPN-01' "$host" "$HEADSCALE_LIB")
    else
        listen_addr="0.0.0.0:8080"
        tls_block='tls_letsencrypt_hostname: ""'
        log_warn "URL is not https; headscale will serve plain HTTP on :8080 (clients need an https endpoint or a TLS proxy)."
    fi
    as_root mkdir -p /etc/headscale "$HEADSCALE_LIB"
    as_root tee "$HEADSCALE_CONFIG" >/dev/null <<EOF
# Generated by connector $(date -u +%Y-%m-%dT%H:%M:%SZ)
server_url: ${url}
listen_addr: ${listen_addr}
metrics_listen_addr: 127.0.0.1:9090
grpc_listen_addr: 127.0.0.1:50443
grpc_allow_insecure: false

noise:
  private_key_path: ${HEADSCALE_LIB}/noise_private.key

prefixes:
  v4: 100.64.0.0/10
  v6: fd7a:115c:a1e0::/48
  allocation: sequential

derp:
  server:
    enabled: true
    region_id: 999
    region_code: "headscale"
    region_name: "Connector Embedded DERP"
    stun_listen_addr: "0.0.0.0:3478"
    private_key_path: ${HEADSCALE_LIB}/derp_server_private.key
    automatically_add_embedded_derp_region: true
  urls: []
  paths: []
  auto_update_enabled: false
  update_frequency: 24h

disable_check_updates: true

database:
  type: sqlite
  sqlite:
    path: ${HEADSCALE_LIB}/db.sqlite

${tls_block}

log:
  level: info
  format: text

policy:
  mode: file
  path: ${HEADSCALE_ACL}

dns:
  magic_dns: true
  base_domain: ${base_domain}
  nameservers:
    global:
      - 1.1.1.1
      - 1.0.0.1
  search_domains: []

unix_socket: /var/run/headscale/headscale.sock
unix_socket_permission: "0770"
EOF
    as_root chmod 644 "$HEADSCALE_CONFIG"
}

write_acl() {
    as_root mkdir -p /etc/headscale
    as_root tee "$HEADSCALE_ACL" >/dev/null <<EOF
{
  "tagOwners": {
    "tag:provider": ["${HEADSCALE_USER}"],
    "tag:consumer": ["${HEADSCALE_USER}"]
  },
  "acls": [
    { "action": "accept", "src": ["tag:consumer"], "dst": ["tag:provider:*"] }
  ],
  "ssh": [
    {
      "action": "accept",
      "src": ["tag:consumer"],
      "dst": ["tag:provider"],
      "users": ["autogroup:nonroot"]
    }
  ]
}
EOF
    as_root chmod 644 "$HEADSCALE_ACL"
}

open_firewall() {
    if have ufw; then
        as_root ufw allow 443/tcp   >/dev/null 2>&1 || true
        as_root ufw allow 3478/udp  >/dev/null 2>&1 || true
        as_root ufw allow 41641/udp >/dev/null 2>&1 || true
        log_success "ufw rules added (443/tcp, 3478/udp, 41641/udp)"
    elif have firewall-cmd; then
        as_root firewall-cmd --permanent --add-port=443/tcp   >/dev/null 2>&1 || true
        as_root firewall-cmd --permanent --add-port=3478/udp  >/dev/null 2>&1 || true
        as_root firewall-cmd --permanent --add-port=41641/udp >/dev/null 2>&1 || true
        as_root firewall-cmd --reload >/dev/null 2>&1 || true
        log_success "firewalld rules added (443/tcp, 3478/udp, 41641/udp)"
    else
        log_warn "No ufw/firewalld found. Open manually: 443/tcp, 3478/udp, 41641/udp"
    fi
}

ensure_headscale_user() {
    if as_root headscale users list 2>/dev/null | grep -qw "$HEADSCALE_USER"; then
        log_info "headscale user '$HEADSCALE_USER' already exists"
    else
        as_root headscale users create "$HEADSCALE_USER" >/dev/null 2>&1 \
            || log_warn "Could not create headscale user '$HEADSCALE_USER' (may already exist)"
        log_success "headscale user '$HEADSCALE_USER' ready"
    fi
}

cnc_init_local() {
    local url="$1" base_domain="$2"
    require_root cnc-init
    [ -n "$url" ] || die "Usage: connector cnc-init --url https://vpn.example.com"
    [ -n "$base_domain" ] || base_domain="connector.mesh"

    log_info "Initialising CNC (headscale) for ${url} (MagicDNS base: ${base_domain})"
    have curl || as_root apt-get install -y curl >/dev/null 2>&1 || true
    install_headscale
    write_headscale_config "$url" "$base_domain"
    write_acl
    log_info "Enabling + starting headscale..."
    as_root systemctl enable --now headscale >/dev/null 2>&1 || as_root systemctl restart headscale
    sleep 2
    ensure_headscale_user
    open_firewall

    echo
    log_success "CNC ready at ${url}"
    echo "Next: authorize a machine:"
    echo "    connector invite            # choose provider/consumer; prints a register command"
}

# --- cnc-init dispatcher + remote orchestration + link ----------------------
cmd_cnc_init() {
    local host="" url="" port="" base_domain=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --url)         url="$2"; shift 2 ;;
            --base-domain) base_domain="$2"; shift 2 ;;
            -p|--port)     port="$2"; shift 2 ;;
            -*) die "Unknown option: $1" ;;
            *) [ -z "$host" ] && host="$1" || die "Unexpected argument: $1"; shift ;;
        esac
    done
    if [ -n "$host" ]; then
        cnc_init_remote "$host" "$url" "$port"
    else
        cnc_init_local "$url" "$base_domain"
    fi
}

cnc_init_remote() {
    local host="$1" url="$2" port="$3" sshflag scpflag self
    [ -n "$url" ] || die "Usage: connector cnc-init <user@host> --url https://vpn.example.com [-p port]"
    have ssh || die "ssh not found"; have scp || die "scp not found"
    sshflag="$([ -n "$port" ] && echo "-p $port" || true)"
    scpflag="$([ -n "$port" ] && echo "-P $port" || true)"

    log_info "Checking SSH access to $host..."
    # shellcheck disable=SC2086
    ssh -o ConnectTimeout=10 $sshflag "$host" true || die "Cannot SSH to $host"

    # shellcheck disable=SC2086
    if ssh $sshflag "$host" 'test -f /etc/headscale/config.yaml && systemctl is-active --quiet headscale' 2>/dev/null; then
        log_info "CNC already configured on $host; skipping install."
    else
        log_info "Copying connector to $host and running cnc-init..."
        self="$(self_path)"
        # shellcheck disable=SC2086
        scp $scpflag "$self" "$host:/tmp/connector.$$" >/dev/null
        # shellcheck disable=SC2086
        ssh $sshflag "$host" "sudo install -m 0755 /tmp/connector.$$ ${CONNECTOR_BIN} && rm -f /tmp/connector.$$"
        # shellcheck disable=SC2086
        ssh -t $sshflag "$host" "sudo ${CONNECTOR_BIN} cnc-init --url '$url'" || die "Remote cnc-init failed"
    fi

    save_cnc_link "$host" "$url" "$port"
    log_success "Linked to CNC $host (this machine is now a controller)."

    echo
    echo "Register this machine on the tailnet?"
    echo "  [1] provider   [2] consumer   (enter '1 2' for both)   [s] skip"
    local choice; read -r -p "Choose: " choice || choice="s"
    local type=""
    case "$(echo "$choice" | tr -d ' ')" in
        1)        type="provider" ;;
        2)        type="consumer" ;;
        12|21)    type="both" ;;
        ''|s|S)   type="" ;;
        *) log_warn "Unrecognised choice; skipping." ;;
    esac
    if [ -n "$type" ]; then
        local key; key="$(mint_key "$type")"
        cmd_register "$type" "$url" --authkey "$key" --yes
    else
        log_info "Skipped. Invite machines later with: connector invite"
    fi
}

cmd_link() {
    local host="" url="" port="" sshflag
    while [ $# -gt 0 ]; do
        case "$1" in
            --url)     url="$2"; shift 2 ;;
            -p|--port) port="$2"; shift 2 ;;
            -*) die "Unknown option: $1" ;;
            *) [ -z "$host" ] && host="$1" || die "Unexpected argument: $1"; shift ;;
        esac
    done
    [ -n "$host" ] && [ -n "$url" ] || die "Usage: connector link <user@host> --url https://vpn.example.com [-p port]"
    sshflag="$([ -n "$port" ] && echo "-p $port" || true)"
    log_info "Verifying CNC at $host..."
    # shellcheck disable=SC2086
    ssh -o ConnectTimeout=10 $sshflag "$host" 'test -f /etc/headscale/config.yaml' \
        || die "$host is not a configured CNC (no /etc/headscale/config.yaml)"
    save_cnc_link "$host" "$url" "$port"
    log_success "Linked to CNC $host. This machine is now a controller."
    echo "Try: connector list"
}

# --- Invite ------------------------------------------------------------------
hs_user_id() {
    local out id
    out="$(hs users list --output json 2>/dev/null)" || return 1
    id="$(printf '%s' "$out" | tr '{}' '\n\n' \
         | grep "\"name\":\"$HEADSCALE_USER\"" | head -n1 \
         | sed -n 's/.*"id":[[:space:]]*"\{0,1\}\([0-9]\+\).*/\1/p')"
    [ -n "$id" ] && printf '%s\n' "$id"
}

# Mint a single-use, short-expiry pre-auth key for a type; echo the key.
mint_key() {
    local type="$1" tags user uid out key
    case "$type" in
        provider) tags="tag:provider" ;;
        consumer) tags="tag:consumer" ;;
        both)     tags="tag:provider,tag:consumer" ;;
        *) die "Invalid type: $type" ;;
    esac
    user="$HEADSCALE_USER"
    uid="$(hs_user_id 2>/dev/null || true)"
    [ -n "$uid" ] && user="$uid"
    out="$(hs preauthkeys create --user "$user" --tags "$tags" --expiration "$KEY_EXPIRY" --output json 2>/dev/null)" \
        || die "Failed to create pre-auth key on CNC"
    key="$(printf '%s' "$out" | json_str key)"
    [ -n "$key" ] || die "Could not parse pre-auth key from headscale output"
    printf '%s\n' "$key"
}

cmd_invite() {
    is_admin || die "Only a CNC or controller can invite. Link one: connector link <host> --url ..."
    local types=() name="" want_controller=0
    while [ $# -gt 0 ]; do
        case "$1" in
            provider) types+=("provider"); shift ;;
            consumer) types+=("consumer"); shift ;;
            controller|commander) want_controller=1; shift ;;
            *) name="$1"; shift ;;
        esac
    done

    if [ "${#types[@]}" -eq 0 ] && [ "$want_controller" -eq 0 ]; then
        echo "Invite as:"
        echo "  [1] provider"
        echo "  [2] consumer"
        echo "  [3] controller (C&C commander)"
        local sel n
        read -r -p 'Enter number(s) (e.g. 1, 2, or "1 2"): ' sel || sel=""
        for n in $sel; do
            case "$n" in
                1) types+=("provider") ;;
                2) types+=("consumer") ;;
                3) want_controller=1 ;;
                *) log_warn "Ignoring invalid choice: $n" ;;
            esac
        done
    fi
    [ "${#types[@]}" -eq 0 ] && [ "$want_controller" -eq 0 ] && die "Nothing selected."

    if [ "$want_controller" -eq 1 ]; then
        invite_controller
    fi

    if [ "${#types[@]}" -gt 0 ]; then
        local type url key hostarg=""
        if printf '%s\n' "${types[@]}" | grep -qx provider && printf '%s\n' "${types[@]}" | grep -qx consumer; then
            type="both"
        else
            type="${types[0]}"
        fi
        url="$(cnc_server_url)"; [ -n "$url" ] || url="<server-url>"
        key="$(mint_key "$type")"
        [ -n "$name" ] && hostarg=" --hostname $name"
        echo
        log_success "Single-use invite created (type: ${type}, expires in ${KEY_EXPIRY})."
        echo "Run this on the new machine:"
        echo
        echo "    connector register ${type} ${url} --authkey ${key}${hostarg}"
        echo
    fi
}

invite_controller() {
    is_admin || die "Only a CNC or controller can invite a controller."
    local url cnc_target pubkey
    url="$(cnc_server_url)"
    if is_controller; then load_cnc_link; cnc_target="$CNC_SSH"; else cnc_target="$(id -un)@$(hostname -f 2>/dev/null || hostname)"; fi

    echo
    echo "== Invite a controller (C&C commander) =="
    echo "A controller commands the CNC over SSH, so its key must be authorized"
    echo "on the CNC admin account (${cnc_target})."
    echo "On the NEW controller, run 'connector commander-key' and paste its output here."
    echo
    read -r -p "Paste SSH public key: " pubkey || true
    [ -n "$pubkey" ] || die "No key provided."
    case "$pubkey" in
        ssh-*|ecdsa-*|sk-*) ;;
        *) die "That does not look like an SSH public key." ;;
    esac
    authorize_commander "$pubkey"
    log_success "Authorized the new controller's key on the CNC admin account."
    echo
    echo "Tell them to run:"
    echo "    connector link ${cnc_target} --url ${url}${CNC_PORT:+ -p $CNC_PORT}"
}

# Append a public key to the CNC admin account's authorized_keys.
authorize_commander() {
    local pubkey="$1"
    if is_cnc; then
        mkdir -p "$HOME/.ssh"; chmod 700 "$HOME/.ssh"
        printf '%s\n' "$pubkey" >> "$HOME/.ssh/authorized_keys"
        chmod 600 "$HOME/.ssh/authorized_keys"
    else
        load_cnc_link
        printf '%s\n' "$pubkey" | ssh_cnc 'umask 077; mkdir -p "$HOME/.ssh"; cat >> "$HOME/.ssh/authorized_keys"'
    fi
}

cmd_commander_key() {
    local k key=""
    for k in "$HOME/.ssh/id_ed25519.pub" "$HOME/.ssh/id_ecdsa.pub" "$HOME/.ssh/id_rsa.pub"; do
        [ -f "$k" ] && { key="$k"; break; }
    done
    if [ -z "$key" ]; then
        log_info "No SSH key found; generating an ed25519 key..."
        ssh-keygen -t ed25519 -N "" -f "$HOME/.ssh/id_ed25519" -C "connector-commander@$(hostname)" >/dev/null
        key="$HOME/.ssh/id_ed25519.pub"
    fi
    echo "# Hand this public key to a CNC/controller running 'connector invite' -> controller:"
    cat "$key"
}

# --- Register (join the tailnet) --------------------------------------------
is_wsl()        { grep -qiE "(microsoft|wsl)" /proc/version 2>/dev/null || [ -n "${WSL_DISTRO_NAME:-}" ]; }
systemd_active() { [ -d /run/systemd/system ]; }

install_tailscale() {
    have tailscale && return 0
    log_info "Installing tailscale..."
    curl -fsSL "$TS_INSTALL_URL" | sh
    have tailscale || die "tailscale installation failed."
}

# Consent-gated, idempotent WSL systemd enablement. Returns non-zero to abort.
ensure_wsl_systemd() {
    is_wsl || return 0
    systemd_active && return 0
    if grep -qs "systemd=true" /etc/wsl.conf 2>/dev/null; then
        log_warn "systemd is enabled in /etc/wsl.conf but not active yet."
        log_warn "Run 'wsl --shutdown' in Windows, reopen this distro, then re-run register."
        return 1
    fi
    log_warn "tailscale needs systemd, which is not enabled in this WSL distro."
    confirm "Enable systemd in /etc/wsl.conf now?" || { log_error "Cannot continue without systemd."; return 1; }
    as_root bash -c 'touch /etc/wsl.conf
if ! grep -q "^\[boot\]" /etc/wsl.conf; then
    printf "\n[boot]\nsystemd=true\n" >> /etc/wsl.conf
elif ! grep -q "systemd=true" /etc/wsl.conf; then
    sed -i "/^\[boot\]/a systemd=true" /etc/wsl.conf
fi'
    log_success "Enabled systemd in /etc/wsl.conf."
    log_warn "Now run 'wsl --shutdown' in Windows PowerShell, reopen this distro, then re-run your connector register command."
    return 1
}

maybe_fix_wsl_mtu() {
    is_wsl || return 0
    have ip || return 0
    local mtu
    mtu="$(ip link show tailscale0 2>/dev/null | sed -n 's/.* mtu \([0-9]\+\).*/\1/p' | head -n1)"
    if [ -n "$mtu" ] && [ "$mtu" -gt "$WSL_MTU" ]; then
        log_info "Pinning tailscale0 MTU to ${WSL_MTU} (WSL large-packet fix)..."
        as_root ip link set tailscale0 mtu "$WSL_MTU" 2>/dev/null || true
    fi
}

cmd_register() {
    local type="${1:-}"; shift || true
    case "$type" in
        provider|consumer|both) ;;
        *) die "Usage: connector register <provider|consumer|both> <url> [--authkey KEY] [--hostname N] [--yes]" ;;
    esac
    local url="" key="" hostname=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --authkey)  key="$2"; shift 2 ;;
            --hostname) hostname="$2"; shift 2 ;;
            --yes|-y)   ASSUME_YES=1; shift ;;
            -*) die "Unknown option: $1" ;;
            *) [ -z "$url" ] && url="$1" || die "Unexpected argument: $1"; shift ;;
        esac
    done
    [ -n "$url" ] || die "Usage: connector register <provider|consumer|both> <url> [--authkey KEY]"

    ensure_wsl_systemd || return 0
    install_tailscale
    [ -n "$hostname" ] || hostname="$(hostname -s 2>/dev/null || hostname)"

    local tags ssh_flag=""
    case "$type" in
        provider) tags="tag:provider"; ssh_flag="--ssh" ;;
        consumer) tags="tag:consumer" ;;
        both)     tags="tag:provider,tag:consumer"; ssh_flag="--ssh" ;;
    esac

    log_info "Bringing up tailscale (type: $type, hostname: $hostname)..."
    local up_args=(--login-server "$url" --hostname "$hostname" --advertise-tags="$tags" --accept-dns=true)
    [ -n "$ssh_flag" ] && up_args+=("$ssh_flag")
    [ -n "$key" ] && up_args+=(--authkey "$key")

    if ! as_root tailscale up "${up_args[@]}"; then
        if [ -z "$key" ]; then
            log_warn "No --authkey supplied; tailscale printed a login URL above."
            log_warn "Ask the CNC admin to approve it:  connector approve"
        fi
        die "tailscale up did not complete."
    fi

    mkdir -p "$STATE_DIR"; chmod 700 "$STATE_DIR" 2>/dev/null || true
    printf '%s\n' "$type" > "$ROLE_FILE"
    maybe_fix_wsl_mtu

    local ts_ip ts_name
    ts_ip="$(tailscale ip -4 2>/dev/null | head -n1 || true)"
    ts_name="$(tailscale status --json 2>/dev/null | json_str DNSName)"; ts_name="${ts_name%.}"
    [ -n "$ts_name" ] || ts_name="$hostname"

    echo
    log_success "Connected as ${type}."
    [ -n "$ts_ip" ] && echo "  Tailnet IP: $ts_ip"
    echo "  MagicDNS:   $ts_name"
    case "$type" in
        provider|both) echo "  Others reach you via:  ssh <user>@${ts_name}" ;;
    esac
    case "$type" in
        consumer|both) echo "  Reach a provider via:  connector hop <provider-name>" ;;
    esac
}

# --- Admin: list / approve / revoke -----------------------------------------
cmd_list() {
    is_admin || die "Only a CNC or controller can list nodes."
    hs nodes list
}

approve_routes() {
    local id="$1"
    # Route-approval CLI differs across headscale versions; best-effort, never fatal.
    hs nodes approve-routes --identifier "$id" --routes "" >/dev/null 2>&1 \
        || hs routes enable --identifier "$id" >/dev/null 2>&1 \
        || true
}

cmd_approve() {
    is_admin || die "Only a CNC or controller can approve."
    local node="${1:-}" type="${2:-}"
    if [ -z "$node" ]; then
        echo "Nodes:"
        hs nodes list
        echo
        echo "Tag/approve a node that joined without a key:"
        echo "    connector approve <node-name|id> <provider|consumer|both>"
        echo
        echo "(Simpler: 'connector invite' issues a single-use key so no approval step is needed.)"
        return 0
    fi
    local id; id="$(resolve_node_id "$node")" || die "Node not found: $node"
    approve_routes "$id"
    if [ -n "$type" ]; then
        local tags
        case "$type" in
            provider) tags="tag:provider" ;;
            consumer) tags="tag:consumer" ;;
            both)     tags="tag:provider,tag:consumer" ;;
            *) die "type must be provider|consumer|both" ;;
        esac
        hs nodes tag --identifier "$id" --tags "$tags"
        log_success "Tagged node $node as $type."
    fi
    log_success "Approved node $node (id $id)."
}

cmd_revoke() {
    is_admin || die "Only a CNC or controller can revoke nodes."
    local node="${1:-}"
    [ -n "$node" ] || die "Usage: connector revoke <node-name|node-id>"
    local id; id="$(resolve_node_id "$node")" || die "Node not found: $node"
    log_warn "Revoking node $node (id $id)..."
    hs nodes delete --identifier "$id" --force 2>/dev/null || hs nodes delete --identifier "$id"
    log_success "Revoked $node."
}

# --- Status / whoami ---------------------------------------------------------
cmd_status() {
    echo "Roles: $(current_roles)"
    if is_controller; then load_cnc_link; echo "Linked CNC: $CNC_SSH ($CNC_URL)"; fi
    echo
    if is_cnc; then
        if systemctl is-active --quiet headscale 2>/dev/null; then
            log_success "headscale service is running"
        else
            log_warn "headscale service is not running"
        fi
        echo
        as_root headscale nodes list 2>/dev/null || true
        return 0
    fi
    if have tailscale; then
        tailscale status || log_warn "tailscale not connected"
    else
        log_warn "tailscale is not installed on this machine."
    fi
}

cmd_whoami() {
    echo "Roles: $(current_roles)"
    if is_controller; then load_cnc_link; echo "Linked CNC: $CNC_SSH"; echo "Server URL: $CNC_URL"; fi
    if is_cnc; then echo "Server URL: $(cnc_server_url)"; fi
    if is_node; then
        local ip; ip="$(tailscale ip -4 2>/dev/null | head -n1 || true)"
        [ -n "$ip" ] && echo "Tailnet IP: $ip"
    fi
}

# --- hop / alias -------------------------------------------------------------
cmd_hop() {
    local target="${1:-}"
    if [ -z "$target" ]; then
        log_info "Tailnet peers (providers accept SSH):"
        have tailscale && tailscale status 2>/dev/null \
            | awk 'NF>=2 && $1 !~ /^#/ {print "  " $2 "  (" $1 ")"}'
        echo
        echo "Connect with: connector hop <name>   (or: ssh <user>@<name>)"
        return 0
    fi
    if [[ "$target" == *"@"* ]]; then
        ssh "$target"
    else
        ssh "$(id -un)@${target}"
    fi
}

is_reserved() { local n; for n in "${RESERVED_COMMANDS[@]}"; do [ "$1" = "$n" ] && return 0; done; return 1; }

ensure_aliases_file() {
    mkdir -p "$STATE_DIR"; chmod 700 "$STATE_DIR" 2>/dev/null || true
    [ -f "$ALIASES_FILE" ] || {
        printf '# connector aliases\n# format: name|user@magicdns-name\n' > "$ALIASES_FILE"
        chmod 600 "$ALIASES_FILE"
    }
}
alias_lookup() { [ -f "$ALIASES_FILE" ] && grep -E "^$1\|" "$ALIASES_FILE" 2>/dev/null | head -n1; }

cmd_alias() {
    local sub="${1:-list}"
    case "$sub" in
        ""|list|ls)
            ensure_aliases_file
            printf "%-20s %s\n" "NAME" "TARGET"
            local n t c=0
            while IFS='|' read -r n t; do
                [ -z "$n" ] && continue
                [[ "$n" == \#* ]] && continue
                printf "%-20s %s\n" "$n" "$t"; c=$((c+1))
            done < "$ALIASES_FILE"
            [ "$c" -eq 0 ] && echo "(none) - add one: connector alias <name> <user@magicdns-name>"
            ;;
        rm|remove|delete)
            local name="${2:-}"; [ -n "$name" ] || die "Usage: connector alias rm <name>"
            ensure_aliases_file
            local tmp; tmp="$(mktemp)"
            grep -vE "^$name\|" "$ALIASES_FILE" > "$tmp" 2>/dev/null || true
            mv "$tmp" "$ALIASES_FILE"; chmod 600 "$ALIASES_FILE"
            ssh_config_remove_block "$name"
            log_success "Removed alias $name"
            ;;
        *)
            local name="$1" target="${2:-}"
            [ -n "$name" ] && [ -n "$target" ] || die "Usage: connector alias <name> <user@magicdns-name>"
            is_reserved "$name" && die "Alias '$name' conflicts with a built-in command."
            ensure_aliases_file
            local tmp; tmp="$(mktemp)"
            grep -vE "^$name\|" "$ALIASES_FILE" > "$tmp" 2>/dev/null || true
            mv "$tmp" "$ALIASES_FILE"
            printf '%s|%s\n' "$name" "$target" >> "$ALIASES_FILE"; chmod 600 "$ALIASES_FILE"
            log_success "Saved alias $name -> $target   (run: connector $name)"
            if confirm "Add a matching ~/.ssh/config Host entry so 'ssh $name' works?"; then
                ssh_config_add_block "$name" "$target"
            fi
            ;;
    esac
}

ssh_config_add_block() {
    local name="$1" target="$2" user host
    if [[ "$target" == *"@"* ]]; then user="${target%@*}"; host="${target##*@}"; else user="$(id -un)"; host="$target"; fi
    mkdir -p "$(dirname "$SSH_CONFIG_FILE")"; chmod 700 "$(dirname "$SSH_CONFIG_FILE")" 2>/dev/null || true
    touch "$SSH_CONFIG_FILE"; chmod 600 "$SSH_CONFIG_FILE"
    if grep -qF "# BEGIN connector alias $name" "$SSH_CONFIG_FILE" 2>/dev/null; then
        log_warn "$SSH_CONFIG_FILE already has '$name'"; return 0
    fi
    cat >> "$SSH_CONFIG_FILE" <<EOF

# BEGIN connector alias $name
Host $name
    HostName $host
    User $user
# END connector alias $name
EOF
    log_success "Added Host '$name' to $SSH_CONFIG_FILE"
}

ssh_config_remove_block() {
    local name="$1" tmp
    [ -f "$SSH_CONFIG_FILE" ] || return 0
    grep -qF "# BEGIN connector alias $name" "$SSH_CONFIG_FILE" 2>/dev/null || return 0
    tmp="$(mktemp)"
    awk -v m="connector alias $name" '
        $0 == "# BEGIN " m {s=1; next}
        s && $0 == "# END " m {s=0; next}
        !s {print}' "$SSH_CONFIG_FILE" > "$tmp"
    mv "$tmp" "$SSH_CONFIG_FILE"; chmod 600 "$SSH_CONFIG_FILE"
    log_success "Removed Host '$name' from $SSH_CONFIG_FILE"
}

# --- Cleanup -----------------------------------------------------------------
cmd_cleanup() {
    log_warn "This will disconnect this machine from the tailnet."
    confirm "Continue?" || { log_info "Cancelled."; exit 0; }
    if have tailscale; then
        as_root tailscale logout 2>/dev/null || true
        as_root tailscale down 2>/dev/null || true
    fi
    rm -f "$ROLE_FILE"
    if is_controller && confirm "Also forget the linked CNC?"; then
        rm -f "$CNC_LINK_FILE"; log_success "Forgot CNC link."
    fi
    log_success "Cleanup complete."
}

cmd_cleanup_cnc() {
    is_admin || die "Only a CNC or controller can run cleanup-cnc."
    log_warn "This will delete ALL nodes and stop headscale on the CNC."
    confirm "Continue?" || { log_info "Cancelled."; exit 0; }
    local out ids id
    out="$(hs nodes list --output json 2>/dev/null)" || out=""
    ids="$(printf '%s' "$out" | tr '{}' '\n\n' \
         | sed -n 's/.*"id":[[:space:]]*"\{0,1\}\([0-9]\+\).*/\1/p' | sort -un)"
    for id in $ids; do
        hs nodes delete --identifier "$id" --force >/dev/null 2>&1 || true
    done
    if is_cnc; then
        as_root systemctl stop headscale 2>/dev/null || true
        as_root systemctl disable headscale 2>/dev/null || true
    else
        ssh_cnc 'sudo systemctl stop headscale; sudo systemctl disable headscale' 2>/dev/null || true
    fi
    log_success "CNC cleaned up (nodes deleted, headscale stopped)."
    echo
    echo "Migrating from the old WireGuard connector? Tear down leftover state if present:"
    echo "  sudo systemctl disable --now wg-quick@wg-connector"
    echo "  sudo rm -f /etc/wireguard/wg-connector.conf"
    echo "  sudo rm -rf /var/lib/wsl-registry; sudo userdel -r connector 2>/dev/null"
    echo "  and remove any 'Match User connector' blocks from /etc/ssh/sshd_config"
}

# --- Help --------------------------------------------------------------------
cmd_help() {
    cat <<EOF
connector v${VERSION} - headscale/tailscale mesh manager

This machine: $(current_roles)

SETUP
  cnc-init [user@host] --url https://HOST [-p PORT]
                       Set up the CNC (headscale). With user@host it runs
                       remotely over SSH and links this PC as a controller.
  link <user@host> --url https://HOST [-p PORT]
                       Attach to an existing CNC (become a controller).

ONBOARD                [admin: run on the CNC or a linked controller]
  invite [provider] [consumer] [controller] [name]
                       No args -> menu ([1] provider [2] consumer
                       [3] controller). Enter "1 2" for both. Mints a
                       single-use key and prints the register command.
  commander-key        Print this machine's SSH public key (for a
                       'controller' invite).
  approve [node] [type]
                       Tag/approve a node that joined without a key.

JOIN
  register <provider|consumer|both> <url> [--authkey KEY] [--hostname N] [--yes]
                       Join the tailnet. Auto-handles WSL systemd (asks first).

USE
  status               Roles + tailscale/headscale status.
  whoami               Detected role(s) + linked CNC.
  list                 [admin] List nodes.
  revoke <node>        [admin] Remove a node.
  hop [user@name|name] SSH to a provider by MagicDNS name (no arg = list).
  alias <name> <user@name> | alias list | alias rm <name>
                       Save an SSH shortcut (optionally writes ~/.ssh/config).
  cleanup              Disconnect this machine from the tailnet.
  cleanup-cnc          [admin] Delete all nodes + stop headscale.
  help                 This help.

Examples
  connector cnc-init root@203.0.113.1 --url https://vpn.example.com
  connector invite consumer
  connector register consumer https://vpn.example.com --authkey hskey-xxxx
  connector hop my-laptop
EOF
}

# --- Dispatcher --------------------------------------------------------------
main() {
    local cmd="${1:-help}"; shift || true
    case "$cmd" in
        cnc-init)       cmd_cnc_init "$@" ;;
        link)           cmd_link "$@" ;;
        invite)         cmd_invite "$@" ;;
        commander-key)  cmd_commander_key "$@" ;;
        register)       cmd_register "$@" ;;
        approve)        cmd_approve "$@" ;;
        list)           cmd_list "$@" ;;
        revoke)         cmd_revoke "$@" ;;
        status)         cmd_status "$@" ;;
        whoami)         cmd_whoami "$@" ;;
        hop)            cmd_hop "$@" ;;
        alias)          cmd_alias "$@" ;;
        cleanup)        cmd_cleanup "$@" ;;
        cleanup-cnc)    cmd_cleanup_cnc "$@" ;;
        help|--help|-h) cmd_help ;;
        *)
            local line target
            line="$(alias_lookup "$cmd" || true)"
            if [ -n "$line" ]; then
                target="${line#*|}"
                cmd_hop "$target"
                exit $?
            fi
            log_error "Unknown command: $cmd"
            echo
            cmd_help
            exit 1
            ;;
    esac
}

main "$@"
