                       server via 'cnc' or its ssh remote name (e.g. 'connector
                       nyc'). Aliases: 'connector ssh <name>'; any non-command
                       word is an implicit hop -> 'connector <name>'.
                       -t/--tmux opens a persistent tmux session (survives
                       disconnects, and reboots on systemd hosts; uses your
                       ~/.tmux.conf). Default session is 'main'; name it with a
                       second word or -s. -a picks an existing session (a name
                       attaches strictly), -l lists, -k [name] kills.
  alias <name> <user@name> | alias list | alias rm <name>
                       Save an SSH shortcut (optionally writes ~/.ssh/config).
  cleanup              Disconnect this machine from the tailnet.
  cleanup-cnc          [admin] Delete all nodes + stop headscale.
  help                 This help.

Examples
  connector cnc-init root@203.0.113.1            # no domain; self-signs TLS on :${HS_TLS_PORT_DEFAULT}
  connector cnc-init root@203.0.113.1 --url https://vpn.example.com   # with a domain
  connector invite consumer
  connector register consumer https://203.0.113.1:${HS_TLS_PORT_DEFAULT} --authkey hskey-xxxx --ca-sha256 ab12...
  connector hop my-laptop
  connector hop -t my-laptop work                # persistent tmux session 'work'
EOF
    echo
    print_hosts
}

# Once per hour, warn a manager if the CNC's connector differs and offer to sync.
maybe_check_cnc_sync() {
    is_manager || return 0
    [ -t 0 ] || return 0                     # interactive sessions only
    local stamp="$STATE_DIR/.synccheck" now=0 last=0 self lsum rsum sshflag
    now="$(date +%s 2>/dev/null || echo 0)"
    [ -f "$stamp" ] && last="$(cat "$stamp" 2>/dev/null || echo 0)"
    case "$last" in ''|*[!0-9]*) last=0 ;; esac
    [ "$now" -gt 0 ] && [ "$((now - last))" -lt 3600 ] && return 0
    load_cnc_link
    self="$(self_path)"; lsum="$(file_sha256 "$self")"
    [ -n "$lsum" ] || return 0
    sshflag="$([ -n "${CNC_PORT:-}" ] && echo "-p $CNC_PORT" || true)"
    # shellcheck disable=SC2086
    rsum="$(ssh -o ConnectTimeout=5 -o BatchMode=yes $sshflag "$CNC_SSH" \
        "sha256sum ${CONNECTOR_BIN} 2>/dev/null || shasum -a 256 ${CONNECTOR_BIN} 2>/dev/null" 2>/dev/null \
        | awk '{print $1}' | tr -d '\r')"
    mkdir -p "$STATE_DIR" 2>/dev/null || true
    printf '%s\n' "$now" > "$stamp" 2>/dev/null || true
    [ -n "$rsum" ] || return 0               # CNC unreachable -> skip quietly
    if [ "$lsum" != "$rsum" ]; then
        echo
        log_warn "The CNC's connector is out of sync with this machine."
        confirm "Run 'propagate-update' to sync the CNC (and providers)?" y && cmd_propagate_update
    fi
}

# --- Dispatcher --------------------------------------------------------------
main() {
    local cmd="${1:-help}"; shift || true
    case "$cmd" in
        cnc-init)       cmd_cnc_init "$@" ;;
        cnc-update)     cmd_cnc_update "$@" ;;
        propagate-update) cmd_propagate_update "$@" ;;
        link)           cmd_link "$@" ;;
        invite)         cmd_invite "$@" ;;
        manager-key|commander-key)  cmd_manager_key "$@" ;;
        register)       cmd_register "$@" ;;
        approve)        cmd_approve "$@" ;;
        list|ls)        cmd_list "$@" ;;
        revoke)         cmd_revoke "$@" ;;
        status)         cmd_status "$@" ;;
        whoami)         cmd_whoami "$@" ;;
        hop|ssh)        cmd_hop "$@" ;;
        tmux)           cmd_tmux "$@" ;;
        alias)          cmd_alias "$@" ;;
        cleanup)        cmd_cleanup "$@" ;;
        cleanup-cnc)    cmd_cleanup_cnc "$@" ;;
        help|--help|-h) cmd_help ;;
        *)
            # Not a built-in: treat the whole line as an implicit hop, so
            # 'connector <name>' == 'connector hop <name>' and flags work in
            # any position (e.g. 'connector -t <name>' or 'connector <name> -t').
            # cmd_hop resolves saved aliases on the target token itself.
            cmd_hop "$cmd" "$@"
            exit $?
            ;;
    esac

    # Opportunistically (and throttled) nudge managers when the CNC drifts.
    case "$cmd" in
        invite|list|status|approve|revoke|whoami) maybe_check_cnc_sync || true ;;
    esac
}

main "$@"
