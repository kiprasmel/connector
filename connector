#!/bin/bash
# connector - headscale/tailscale mesh management tool
set -euo pipefail

VERSION="2.2.0"

# --- Constants ---------------------------------------------------------------
HEADSCALE_USER="mesh"
HEADSCALE_CONFIG="/etc/headscale/config.yaml"
HEADSCALE_ACL="/etc/headscale/acl.hujson"
HEADSCALE_LIB="/var/lib/headscale"
HEADSCALE_BIN="/usr/local/bin/headscale"
HEADSCALE_CERT_DIR="${HEADSCALE_LIB}/certs"
HEADSCALE_CERT="${HEADSCALE_CERT_DIR}/cnc.crt"
HEADSCALE_KEY="${HEADSCALE_CERT_DIR}/cnc.key"
HS_TLS_PORT_DEFAULT="8443"
CONNECTOR_BIN="/usr/local/bin/connector"
CON_BIN="/usr/local/bin/con"        # short 'con' shortcut, symlinked to connector
STATE_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/connector"
CNC_LINK_FILE="${STATE_DIR}/cnc"
ROLE_FILE="${STATE_DIR}/role"
CNC_CA_FILE="${STATE_DIR}/cnc-ca.crt"
ALIASES_FILE="${STATE_DIR}/aliases.conf"
TMUX_SOCKET="connector"                       # dedicated tmux server socket (-L)
TMUX_CONF="${STATE_DIR}/tmux.conf"            # connector-managed tmux config
TMUX_USER_CONF="${STATE_DIR}/tmux.user.conf"  # your pushed ~/.tmux.conf
TMUX_RESURRECT_DIR="${STATE_DIR}/resurrect"   # tmux-resurrect save dir (isolated)
SSH_CONFIG_FILE="${HOME}/.ssh/config"
KEY_EXPIRY="${CONNECTOR_KEY_EXPIRY:-1h}"
WSL_MTU="1280"
TS_INSTALL_URL="https://tailscale.com/install.sh"
TS_MAC_APP_CLI="/Applications/Tailscale.app/Contents/MacOS/Tailscale"

RESERVED_COMMANDS=(
    cnc-init cnc-update propagate-update link invite manager-key commander-key register approve list ls revoke
    status whoami hop ssh tmux cnc alias cleanup cleanup-cnc help --help -h
)

# --- Logging -----------------------------------------------------------------
# warn/error lines are also buffered so they can be replayed after a tmux session
# hands the TTY back (tmux's alternate screen otherwise scrolls them out of view).
LOG_NOTES=()
log_info()    { echo "[INFO] $*"; }
log_success() { echo "[OK] $*"; }
log_warn()    { echo "[WARN] $*"; LOG_NOTES+=("[WARN] $*"); }
log_error()   { echo "[ERROR] $*" >&2; LOG_NOTES+=("[ERROR] $*"); }
die()         { log_error "$*"; exit 1; }

# Replay buffered warnings/errors. Call after a full-screen child (tmux) returns,
# so problems printed before it took the screen are still surfaced to the user.
flush_notes() {
    [ "${#LOG_NOTES[@]}" -gt 0 ] || return 0
    printf '\n[i] %d warning(s)/error(s) during this session:\n' "${#LOG_NOTES[@]}" >&2
    local n; for n in "${LOG_NOTES[@]}"; do printf '    %s\n' "$n" >&2; done
    LOG_NOTES=()
}

# --- Small helpers -----------------------------------------------------------
have() { command -v "$1" >/dev/null 2>&1; }

confirm() {
    # confirm "question" [y]  -> returns 0 on yes; ASSUME_YES=1 auto-confirms
    local prompt="$1" default="${2:-n}" reply
    [ "${ASSUME_YES:-0}" = "1" ] && return 0
    if [ "$default" = "y" ]; then
        read -r -p "$prompt [Y/n]: " reply || true
        reply="${reply:-y}"
    else
        read -r -p "$prompt [y/N]: " reply || true
        reply="${reply:-n}"
    fi
    [[ "$reply" =~ ^[Yy]$ ]]
}

require_root() {
    [ "$(id -u)" -eq 0 ] || die "This command must be run as root (try: sudo connector $*)"
}

# Run a command as root locally (no-op prefix when already root).
as_root() {
    if [ "$(id -u)" -eq 0 ]; then "$@"; else sudo "$@"; fi
}

# --- Dependencies ------------------------------------------------------------
# Detect the system package manager (prints a token; empty if none recognised).
pkg_mgr() {
    if   have apt-get; then echo apt
    elif have pacman;  then echo pacman
    elif have dnf;     then echo dnf
    elif have yum;     then echo yum
    elif have zypper;  then echo zypper
    elif have apk;     then echo apk
    elif have brew;    then echo brew
    fi
}

# Package that provides a command for a manager (defaults to the command name).
pkg_for() {
    case "$1:$2" in
        hostname:pacman) echo inetutils ;;
        *)               echo "$1" ;;
    esac
}

# Install packages with the detected manager (refreshing the DB first).
pkg_install() {
    case "$(pkg_mgr)" in
        apt)    as_root apt-get update -qq && as_root apt-get install -y "$@" ;;
        pacman) as_root pacman -Sy --needed --noconfirm "$@" ;;
        dnf)    as_root dnf install -y "$@" ;;
        yum)    as_root yum install -y "$@" ;;
        zypper) as_root zypper --non-interactive install "$@" ;;
        apk)    as_root apk add "$@" ;;
        brew)   brew install "$@" ;;
        *)      return 1 ;;
    esac
}

# Ensure required commands exist; offer to install any that are missing.
# Usage: ensure_deps curl openssl
ensure_deps() {
    local cmd mgr
    local -a missing=() pkgs=()
    for cmd in "$@"; do have "$cmd" || missing+=("$cmd"); done
    [ "${#missing[@]}" -eq 0 ] && return 0

    log_warn "Missing required tool(s): ${missing[*]}"
    mgr="$(pkg_mgr)"
    [ -n "$mgr" ] || die "Please install them with your package manager, then re-run."
    for cmd in "${missing[@]}"; do pkgs+=("$(pkg_for "$cmd" "$mgr")"); done
    confirm "Install ${pkgs[*]} via ${mgr}?" y || die "Cannot continue without: ${missing[*]}"
    log_info "Installing: ${pkgs[*]} ..."
    pkg_install "${pkgs[@]}" || die "Failed to install: ${pkgs[*]}"

    local -a still=()
    for cmd in "${missing[@]}"; do have "$cmd" || still+=("$cmd"); done
    [ "${#still[@]}" -eq 0 ] || die "Still missing after install: ${still[*]}"
}

# Best-effort short hostname that does not require the `hostname` binary
# (Arch base, minimal containers, etc. may not ship it). Empty if unknown;
# tailscale then derives the node name itself.
node_name() {
    local n=""
    if have hostname; then n="$(hostname -s 2>/dev/null || hostname 2>/dev/null || true)"; fi
    if [ -z "$n" ]; then n="${HOSTNAME:-}"; fi
    if [ -z "$n" ] && [ -r /etc/hostname ]; then n="$(cat /etc/hostname 2>/dev/null || true)"; fi
    if [ -z "$n" ]; then n="$(uname -n 2>/dev/null || true)"; fi
    printf '%s\n' "${n%%.*}"
}

# Portable SHA-256 of a file (prints the hex digest; empty if unavailable).
file_sha256() {
    if   have sha256sum; then sha256sum "$1" 2>/dev/null | awk '{print $1}'
    elif have shasum;    then shasum -a 256 "$1" 2>/dev/null | awk '{print $1}'
    fi
}

# Resolve the absolute path of this script, following symlinks.
self_path() {
    local s="${BASH_SOURCE[0]}" d
    while [ -h "$s" ]; do
        d=$(cd -P "$(dirname "$s")" >/dev/null 2>&1 && pwd)
        s=$(readlink "$s")
        case "$s" in /*) ;; *) s="$d/$s" ;; esac
    done
    d=$(cd -P "$(dirname "$s")" >/dev/null 2>&1 && pwd)
    printf '%s/%s\n' "$d" "$(basename "$s")"
}

# Extract a top-level JSON string field ("field":"value") from stdin.
json_str() {
    sed -n 's/.*"'"$1"'":[[:space:]]*"\([^"]*\)".*/\1/p' | head -n1
}

os_kind() {
    case "$(uname -s)" in
        Darwin) echo "macos" ;;
        Linux)  echo "linux" ;;
        *)      echo "other" ;;
    esac
}

# True if $1 looks like a bare IP (v4 or v6), not a DNS hostname.
is_ip() {
    local h="$1"
    case "$h" in *:*) return 0 ;; esac          # IPv6 contains colons
    case "$h" in *[!0-9.]*) return 1 ;; esac     # v4 has only digits + dots
    [ "$(printf '%s' "$h" | tr -cd '.' | wc -c | tr -d ' ')" = "3" ]
}

# Parse host / port out of a URL (handles scheme, [v6]:port, host:port, path).
url_host() {
    local u="${1#*://}"; u="${u%%/*}"
    case "$u" in
        \[*\]*) printf '%s' "${u%%\]*}]" | tr -d '[]' ;;
        *:*)    printf '%s' "${u%%:*}" ;;
        *)      printf '%s' "$u" ;;
    esac
}
url_port() {
    local u="${1#*://}"; u="${u%%/*}"
    case "$u" in
        \[*\]:*) printf '%s' "${u##*]:}" ;;
        \[*\])   printf '' ;;
        *:*)     printf '%s' "${u##*:}" ;;
        *)       printf '' ;;
    esac
}

# SHA-256 fingerprint (lowercase hex, no colons) of a PEM cert on stdin.
fp_of_pem() {
    openssl x509 -noout -fingerprint -sha256 2>/dev/null \
        | sed 's/.*=//; s/://g' | tr 'A-F' 'a-f' | tr -d '[:space:]'
}

# Fetch the leaf cert a TLS server presents: fetch_live_cert <host> <port>
fetch_live_cert() {
    echo | openssl s_client -connect "${1}:${2}" -servername "$1" 2>/dev/null \
        | openssl x509 2>/dev/null
}

# --- Role detection ----------------------------------------------------------
is_cnc()        { have headscale && [ -f "$HEADSCALE_CONFIG" ]; }
is_manager() { [ -f "$CNC_LINK_FILE" ]; }
is_admin()      { is_cnc || is_manager; }

# Does CSV role-list $1 contain role $2?  e.g. role_has "provider,consumer" provider
role_has() { case ",${1}," in *",${2},"*) return 0 ;; *) return 1 ;; esac; }

node_role() {
    local r=""
    [ -f "$ROLE_FILE" ] && r="$(cat "$ROLE_FILE" 2>/dev/null || true)"
    [ "$r" = "both" ] && r="provider,consumer"   # migrate legacy 'both'
    printf '%s' "$r"
}
is_provider() { role_has "$(node_role)" provider; }
is_consumer() { role_has "$(node_role)" consumer; }
is_node()     { have tailscale && tailscale status >/dev/null 2>&1; }

# Canonicalize a comma/space separated node-role spec into an ordered, de-duped
# CSV of tailnet roles (provider[,consumer]). 'both' stays as a legacy alias.
# Dies on any unknown role. Empty input yields empty output (no error).
parse_node_roles() {
    local tok p=0 c=0 out=""
    for tok in $(printf '%s' "${1:-}" | tr ',' ' '); do
        case "$tok" in
            provider) p=1 ;;
            consumer) c=1 ;;
            both)     p=1; c=1 ;;
            *) die "Invalid role: '$tok' (expected provider and/or consumer)" ;;
        esac
    done
    [ "$p" = 1 ] && out="provider"
    [ "$c" = 1 ] && out="${out:+$out,}consumer"
    printf '%s' "$out"
}

# Map a canonical node-role CSV to a tailscale tag CSV (tag:provider[,tag:consumer]).
tags_for_roles() {
    local tags=()
    role_has "$1" provider && tags+=("tag:provider")
    role_has "$1" consumer && tags+=("tag:consumer")
    local IFS=,; printf '%s' "${tags[*]}"
}

current_roles() {
    local roles=()
    is_cnc        && roles+=("cnc")
    is_manager && roles+=("manager")
    is_provider   && roles+=("provider")
    is_consumer   && roles+=("consumer")
    if [ "${#roles[@]}" -eq 0 ]; then
        if is_node; then roles+=("node (untagged)"); else roles+=("unconfigured"); fi
    fi
    echo "${roles[*]}"
}

# --- CNC link state ----------------------------------------------------------
CNC_SSH=""; CNC_URL=""; CNC_PORT=""; CNC_USER=""

# Resolve the login user for an SSH target (honours ~/.ssh/config for aliases).
resolve_ssh_user() {
    local target="$1" user
    case "$target" in
        *@*) printf '%s\n' "${target%@*}"; return 0 ;;
    esac
    user="$(ssh -G "$target" 2>/dev/null | awk '/^user /{print $2; exit}')"
    [ -n "$user" ] && printf '%s\n' "$user"
}

load_cnc_link() {
    [ -f "$CNC_LINK_FILE" ] || die "No CNC linked. Run: connector link <user@host> --url https://..."
    CNC_USER=""
    # shellcheck disable=SC1090
    . "$CNC_LINK_FILE"
    # Prefer a stored user; else derive it (handles bare SSH aliases like 'nyc').
    if [ -z "${CNC_USER:-}" ]; then
        CNC_USER="$(resolve_ssh_user "$CNC_SSH")"
        [ -n "$CNC_USER" ] || CNC_USER="$(id -un)"
    fi
}

save_cnc_link() {
    local ssh_target="$1" url="$2" port="${3:-}" user
    user="$(resolve_ssh_user "$ssh_target")"; [ -n "$user" ] || user="$(id -un)"
    mkdir -p "$STATE_DIR"; chmod 700 "$STATE_DIR" 2>/dev/null || true
    {
        echo "CNC_SSH=\"$ssh_target\""
        echo "CNC_URL=\"$url\""
        echo "CNC_PORT=\"$port\""
        echo "CNC_USER=\"$user\""
    } > "$CNC_LINK_FILE"
    chmod 600 "$CNC_LINK_FILE"
}

_ssh_port_flag() { [ -n "${CNC_PORT:-}" ] && printf -- '-p %s' "$CNC_PORT" || true; }
_scp_port_flag() { [ -n "${CNC_PORT:-}" ] && printf -- '-P %s' "$CNC_PORT" || true; }

# Run an arbitrary command on the CNC over SSH (as the linked admin user).
ssh_cnc() {
    load_cnc_link
    # shellcheck disable=SC2046,SC2086
    ssh -o ConnectTimeout=10 $(_ssh_port_flag) "$CNC_SSH" "$@"
}

# Run a headscale command against the CNC: locally if we are it, else over SSH.
hs() {
    if is_cnc; then
        as_root headscale "$@"
    elif is_manager; then
        load_cnc_link
        if [ "$CNC_USER" = "root" ]; then
            ssh_cnc headscale "$@"
        else
            ssh_cnc sudo headscale "$@"
        fi
    else
        die "Not a CNC and no CNC linked. Run 'connector cnc-init <host> --url ...' or 'connector link <host> --url ...'."
    fi
}

# Print the CNC's server_url (from local config or the saved link).
cnc_server_url() {
    if is_cnc; then
        sed -n 's/^server_url:[[:space:]]*//p' "$HEADSCALE_CONFIG" 2>/dev/null | head -n1
    elif is_manager; then
        load_cnc_link; printf '%s\n' "$CNC_URL"
    fi
}

# Resolve a node name (or numeric id) to a headscale node id.
resolve_node_id() {
    local node="$1" out
    case "$node" in
        ''|*[!0-9]*) ;;                 # not purely numeric -> look up by name
        *) printf '%s\n' "$node"; return 0 ;;
    esac
    out="$(hs nodes list --output json 2>/dev/null)" || return 1
    if have jq; then
        printf '%s' "$out" | jq -r --arg n "$node" \
            'first(.[] | select((.name==$n) or (.given_name==$n)) | .id) // empty' 2>/dev/null | head -n1
        return 0
    fi
    # Fallback for pretty-printed JSON (best-effort; jq strongly preferred).
    printf '%s' "$out" | tr '\n\t' '  ' | sed 's/  */ /g' \
        | grep -o "\"id\": *\"\{0,1\}[0-9]*\"\{0,1\}[^]]*\"given_name\": *\"$node\"" \
        | sed -n 's/.*"id": *"\{0,1\}\([0-9]*\).*/\1/p' | head -n1
}

# --- CNC: install + configure headscale -------------------------------------
detect_arch() {
    case "$(uname -m)" in
        x86_64|amd64)  echo "amd64" ;;
        aarch64|arm64) echo "arm64" ;;
        armv7l|armv6l) echo "arm" ;;
        *) die "Unsupported architecture: $(uname -m)" ;;
    esac
}

install_headscale() {
    if have headscale; then
        log_info "headscale already installed"
        return 0
    fi
    local ver="${HEADSCALE_VERSION:-}"
    if [ -z "$ver" ]; then
        log_info "Resolving latest headscale release..."
        ver="$(curl -fsSL https://api.github.com/repos/juanfont/headscale/releases/latest | json_str tag_name)"
    fi
    [ -n "$ver" ] || die "Could not determine headscale version (set HEADSCALE_VERSION=vX.Y.Z)"
    local arch num tmp
    arch="$(detect_arch)"; num="${ver#v}"; tmp="$(mktemp -d)"
    if have apt-get; then
        log_info "Installing headscale ${ver} (.deb, ${arch})..."
        curl -fsSL -o "$tmp/headscale.deb" \
            "https://github.com/juanfont/headscale/releases/download/${ver}/headscale_${num}_linux_${arch}.deb"
        as_root apt-get update -y
        as_root apt-get install -y "$tmp/headscale.deb"
    else
        log_info "Installing headscale ${ver} (binary, ${arch})..."
        curl -fsSL -o "$tmp/headscale" \
            "https://github.com/juanfont/headscale/releases/download/${ver}/headscale_${num}_linux_${arch}"
        as_root install -m 0755 "$tmp/headscale" "$HEADSCALE_BIN"
        install_headscale_service
    fi
    rm -rf "$tmp"
}

install_headscale_service() {
    log_info "Creating headscale systemd unit..."
    as_root mkdir -p "$HEADSCALE_LIB" /etc/headscale
    as_root tee /etc/systemd/system/headscale.service >/dev/null <<EOF
[Unit]
Description=headscale controller
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=${HEADSCALE_BIN} serve
Restart=always
RestartSec=5
WorkingDirectory=${HEADSCALE_LIB}
RuntimeDirectory=headscale
StateDirectory=headscale

[Install]
WantedBy=multi-user.target
EOF
    as_root systemctl daemon-reload
}

# Generate a long-lived self-signed cert with the IP in the SAN (idempotent).
gen_self_signed() {
    local ip="$1"
    if [ -s "$HEADSCALE_CERT" ] && [ -s "$HEADSCALE_KEY" ] \
        && as_root openssl x509 -in "$HEADSCALE_CERT" -noout -text 2>/dev/null | grep -q "IP Address:${ip}\b"; then
        log_info "Reusing existing self-signed cert for ${ip}"
    else
        have openssl || as_root apt-get install -y openssl >/dev/null 2>&1 || true
        log_info "Generating self-signed TLS cert for ${ip} (10y, P-256)..."
        as_root mkdir -p "$HEADSCALE_CERT_DIR"
        as_root openssl req -x509 -nodes -newkey ec -pkeyopt ec_paramgen_curve:prime256v1 \
            -days 3650 -subj "/CN=${ip}" -addext "subjectAltName=IP:${ip}" \
            -keyout "$HEADSCALE_KEY" -out "$HEADSCALE_CERT" >/dev/null 2>&1 \
            || die "openssl certificate generation failed"
    fi
    # headscale (.deb) runs as user 'headscale'; binary install runs as root.
    as_root chown -R headscale:headscale "$HEADSCALE_CERT_DIR" 2>/dev/null || true
    as_root chmod 750 "$HEADSCALE_CERT_DIR" 2>/dev/null || true
    as_root chmod 640 "$HEADSCALE_KEY"  2>/dev/null || true
    as_root chmod 644 "$HEADSCALE_CERT" 2>/dev/null || true
}

# Print the CNC's self-signed cert PEM (local file on cnc, or over SSH).
cnc_cert_pem() {
    if is_cnc; then
        as_root cat "$HEADSCALE_CERT" 2>/dev/null
    elif is_manager; then
        load_cnc_link
        if [ "$CNC_USER" = "root" ]; then ssh_cnc cat "$HEADSCALE_CERT" 2>/dev/null
        else ssh_cnc sudo cat "$HEADSCALE_CERT" 2>/dev/null; fi
    fi
}

cnc_cert_fingerprint() { cnc_cert_pem | fp_of_pem; }

# p11-kit anchor directories used by Fedora/RHEL, Arch, and SUSE respectively.
CA_ANCHOR_DIRS="/etc/pki/ca-trust/source/anchors /etc/ca-certificates/trust-source/anchors /etc/pki/trust/anchors"

# Add a PEM CA file to the Linux system trust store across distro families.
# Returns non-zero if no trust mechanism could be used.
linux_trust_ca() {
    local crt="$1" d=""
    # Nothing to drive the store yet? Try to install the standard package.
    if ! have update-ca-certificates && ! have update-ca-trust && ! have trust; then
        pkg_install ca-certificates >/dev/null 2>&1 || true
    fi
    if have update-ca-certificates; then            # Debian/Ubuntu (incl. WSL)
        as_root mkdir -p /usr/local/share/ca-certificates || return 1
        as_root install -m 0644 "$crt" /usr/local/share/ca-certificates/headscale-cnc.crt || return 1
        as_root update-ca-certificates >/dev/null 2>&1 || return 1
    elif have update-ca-trust; then                 # Fedora/RHEL/Arch/SUSE (p11-kit)
        for c in $CA_ANCHOR_DIRS; do [ -d "$c" ] && { d="$c"; break; }; done
        [ -n "$d" ] || { d="/etc/ca-certificates/trust-source/anchors"; as_root mkdir -p "$d" || return 1; }
        as_root install -m 0644 "$crt" "$d/headscale-cnc.crt" || return 1
        as_root update-ca-trust extract >/dev/null 2>&1 || as_root update-ca-trust >/dev/null 2>&1 || return 1
    elif have trust; then                            # generic p11-kit
        as_root trust anchor --store "$crt" >/dev/null 2>&1 || return 1
    else
        return 1
    fi
}

# Install + trust a CNC cert (PEM on stdin) in this machine's trust store.
# The local marker (CNC_CA_FILE) is only kept when trust actually succeeds, so
# a failed attempt is retried on the next run instead of being skipped.
trust_cnc_cert() {
    local pem; pem="$(cat)"
    [ -n "$pem" ] || { log_warn "No CNC certificate to trust."; return 1; }
    mkdir -p "$STATE_DIR"; chmod 700 "$STATE_DIR" 2>/dev/null || true
    printf '%s\n' "$pem" > "$CNC_CA_FILE"; chmod 644 "$CNC_CA_FILE"
    case "$(os_kind)" in
        macos)
            log_info "Trusting the CNC certificate in the macOS System keychain (needs sudo)..."
            sudo security add-trusted-cert -d -r trustRoot -p ssl \
                -k /Library/Keychains/System.keychain "$CNC_CA_FILE" \
                || { rm -f "$CNC_CA_FILE"; log_error "Failed to add the cert to the System keychain."; return 1; }
            ;;
        linux)
            linux_trust_ca "$CNC_CA_FILE" \
                || { rm -f "$CNC_CA_FILE"; log_error "Could not add the cert to the system trust store."; return 1; }
            ;;
        *) log_warn "Unknown OS; trust $CNC_CA_FILE manually." ;;
    esac
    log_success "Trusted the CNC certificate."
}

# Remove a previously-trusted CNC cert. untrust_cnc_cert [common-name]
untrust_cnc_cert() {
    local cn="${1:-}" d
    case "$(os_kind)" in
        macos) [ -n "$cn" ] && sudo security delete-certificate -c "$cn" /Library/Keychains/System.keychain 2>/dev/null || true ;;
        linux)
            as_root rm -f /usr/local/share/ca-certificates/headscale-cnc.crt 2>/dev/null || true
            have update-ca-certificates && as_root update-ca-certificates --fresh >/dev/null 2>&1 || true
            for d in $CA_ANCHOR_DIRS; do as_root rm -f "$d/headscale-cnc.crt" 2>/dev/null || true; done
            have update-ca-trust && { as_root update-ca-trust extract >/dev/null 2>&1 || as_root update-ca-trust >/dev/null 2>&1 || true; }
            ;;
    esac
    rm -f "$CNC_CA_FILE" 2>/dev/null || true
}

# Ensure this machine trusts the CNC's self-signed cert (only for IP CNCs).
# establish_cnc_trust <url> [pin-sha256]
establish_cnc_trust() {
    local url="$1" pin="${2:-}" host port pem livefp
    [ "${url%%://*}" = "https" ] || return 0
    host="$(url_host "$url")"; port="$(url_port "$url")"; [ -n "$port" ] || port="443"
    is_ip "$host" || return 0                      # public-domain CNC = publicly-trusted cert
    [ -s "$CNC_CA_FILE" ] && return 0              # already trusted
    if is_manager; then
        pem="$(cnc_cert_pem)"
        [ -n "$pem" ] || die "Could not read the CNC cert over SSH."
    else
        pem="$(fetch_live_cert "$host" "$port")"
        [ -n "$pem" ] || die "Could not fetch a TLS cert from ${host}:${port}."
        livefp="$(printf '%s\n' "$pem" | fp_of_pem)"
        if [ -n "$pin" ]; then
            [ "$livefp" = "$pin" ] || die "CNC cert fingerprint mismatch (pinned $pin, got $livefp)."
        else
            log_warn "No --ca-sha256 pin given; cert presented by ${host}:${port} has fingerprint:"
            log_warn "  $livefp"
            confirm "Trust this CNC certificate?" || die "Declined."
        fi
    fi
    printf '%s\n' "$pem" | trust_cnc_cert
}

write_headscale_config() {
    local url="$1" base_domain="$2" host scheme port listen_addr tls_block
    host="$(url_host "$url")"; port="$(url_port "$url")"
    scheme="${url%%://*}"
    if [ "$scheme" = "https" ] && is_ip "$host"; then
        [ -n "$port" ] || port="$HS_TLS_PORT_DEFAULT"
        listen_addr="0.0.0.0:${port}"
        gen_self_signed "$host"
        tls_block=$(printf 'tls_cert_path: "%s"\ntls_key_path: "%s"\ntls_letsencrypt_hostname: ""' "$HEADSCALE_CERT" "$HEADSCALE_KEY")
    elif [ "$scheme" = "https" ]; then
        [ -n "$port" ] || port="443"
        listen_addr="0.0.0.0:${port}"
        tls_block=$(printf 'tls_letsencrypt_hostname: "%s"\ntls_letsencrypt_cache_dir: %s/cache\ntls_letsencrypt_challenge_type: TLS-ALPN-01' "$host" "$HEADSCALE_LIB")
    else
        [ -n "$port" ] || port="8080"
        listen_addr="0.0.0.0:${port}"
        tls_block='tls_letsencrypt_hostname: ""'
        log_warn "URL is not https; headscale will serve plain HTTP on :${port} (clients need an https endpoint or a TLS proxy)."
    fi
    as_root mkdir -p /etc/headscale "$HEADSCALE_LIB"
    as_root tee "$HEADSCALE_CONFIG" >/dev/null <<EOF
# Generated by connector $(date -u +%Y-%m-%dT%H:%M:%SZ)
server_url: ${url}
listen_addr: ${listen_addr}
metrics_listen_addr: 127.0.0.1:9090
grpc_listen_addr: 127.0.0.1:50443
grpc_allow_insecure: false

noise:
  private_key_path: ${HEADSCALE_LIB}/noise_private.key

prefixes:
  v4: 100.64.0.0/10
  v6: fd7a:115c:a1e0::/48
  allocation: sequential

derp:
  server:
    enabled: true
    region_id: 999
    region_code: "headscale"
    region_name: "Connector Embedded DERP"
    stun_listen_addr: "0.0.0.0:3478"
    private_key_path: ${HEADSCALE_LIB}/derp_server_private.key
    automatically_add_embedded_derp_region: true
  urls: []
  paths: []
  auto_update_enabled: false
  update_frequency: 24h

disable_check_updates: true

database:
  type: sqlite
  sqlite:
    path: ${HEADSCALE_LIB}/db.sqlite

${tls_block}

log:
  level: info
  format: text

policy:
  mode: file
  path: ${HEADSCALE_ACL}

dns:
  magic_dns: true
  base_domain: ${base_domain}
  nameservers:
    global:
      - 1.1.1.1
      - 1.0.0.1
  search_domains: []

unix_socket: /var/run/headscale/headscale.sock
unix_socket_permission: "0770"
EOF
    as_root chmod 644 "$HEADSCALE_CONFIG"
}

write_acl() {
    as_root mkdir -p /etc/headscale
    as_root tee "$HEADSCALE_ACL" >/dev/null <<EOF
{
  "tagOwners": {
    "tag:provider": ["${HEADSCALE_USER}@"],
    "tag:consumer": ["${HEADSCALE_USER}@"]
  },
  "acls": [
    { "action": "accept", "src": ["tag:consumer"], "dst": ["tag:provider:*"] }
  ],
  "ssh": [
    {
      "action": "accept",
      "src": ["tag:consumer"],
      "dst": ["tag:provider"],
      "users": ["autogroup:nonroot"]
    }
  ]
}
EOF
    as_root chmod 644 "$HEADSCALE_ACL"
}

open_firewall() {
    local tcp_port="${1:-$HS_TLS_PORT_DEFAULT}" desc
    desc="${tcp_port}/tcp, 3478/udp, 41641/udp"
    if have ufw && as_root ufw status 2>/dev/null | grep -q "Status: active"; then
        as_root ufw allow "${tcp_port}/tcp" >/dev/null 2>&1 || true
        as_root ufw allow 3478/udp  >/dev/null 2>&1 || true
        as_root ufw allow 41641/udp >/dev/null 2>&1 || true
        log_success "ufw rules added (${desc})"
    elif have firewall-cmd && as_root firewall-cmd --state >/dev/null 2>&1; then
        as_root firewall-cmd --permanent --add-port="${tcp_port}/tcp" >/dev/null 2>&1 || true
        as_root firewall-cmd --permanent --add-port=3478/udp  >/dev/null 2>&1 || true
        as_root firewall-cmd --permanent --add-port=41641/udp >/dev/null 2>&1 || true
        as_root firewall-cmd --reload >/dev/null 2>&1 || true
        log_success "firewalld rules added (${desc})"
    else
        # No active host firewall (e.g. ufw inactive) - do NOT enable one (lockout risk).
        log_info "No active host firewall detected; not enabling one."
        log_info "Ensure these are open (including any cloud firewall): ${desc}"
    fi
}

ensure_headscale_user() {
    if as_root headscale users list 2>/dev/null | grep -qw "$HEADSCALE_USER"; then
        log_info "headscale user '$HEADSCALE_USER' already exists"
    else
        as_root headscale users create "$HEADSCALE_USER" >/dev/null 2>&1 \
            || log_warn "Could not create headscale user '$HEADSCALE_USER' (may already exist)"
        log_success "headscale user '$HEADSCALE_USER' ready"
    fi
}

cnc_init_local() {
    local url="$1" base_domain="$2"
    require_root cnc-init
    [ -n "$url" ] || die "Usage: connector cnc-init --url https://<host-or-ip>[:port]"
    [ -n "$base_domain" ] || base_domain="connector.mesh"

    install_self_local        # ensure 'connector' + 'con' are on PATH on the CNC

    local host port self_signed=0
    host="$(url_host "$url")"; port="$(url_port "$url")"
    if [ "${url%%://*}" = "https" ] && is_ip "$host"; then
        self_signed=1
        # No domain -> headscale serves its own TLS on a dedicated port (default 8443),
        # so it never collides with anything already on :443.
        if [ -z "$port" ]; then port="$HS_TLS_PORT_DEFAULT"; url="https://${host}:${port}"; fi
    fi

    log_info "Initialising CNC (headscale) for ${url}"
    [ "$self_signed" = 1 ] && log_info "TLS: self-signed cert pinned to ${host} (no domain needed)."
    have curl || as_root apt-get install -y curl >/dev/null 2>&1 || true
    install_headscale
    write_headscale_config "$url" "$base_domain"
    write_acl
    log_info "Enabling + starting headscale..."
    as_root systemctl enable headscale >/dev/null 2>&1 || true
    as_root systemctl restart headscale
    sleep 2
    ensure_headscale_user
    open_firewall "${port:-$HS_TLS_PORT_DEFAULT}"

    echo
    if as_root systemctl is-active --quiet headscale; then
        log_success "CNC ready at ${url}"
    else
        log_warn "headscale is not active yet - check: journalctl -u headscale -e"
    fi
    if [ "$self_signed" = 1 ]; then
        echo "  CNC cert SHA-256: $(cnc_cert_fingerprint 2>/dev/null || echo '?')"
    fi
    echo "Next: authorize a machine:  connector invite"
}

# --- cnc-init dispatcher + remote orchestration + link ----------------------
cmd_cnc_init() {
    local host="" url="" port="" base_domain=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --url)         url="$2"; shift 2 ;;
            --base-domain) base_domain="$2"; shift 2 ;;
            -p|--port)     port="$2"; shift 2 ;;
            -*) die "Unknown option: $1" ;;
            *) [ -z "$host" ] && host="$1" || die "Unexpected argument: $1"; shift ;;
        esac
    done
    if [ -n "$host" ]; then
        cnc_init_remote "$host" "$url" "$port"
    else
        cnc_init_local "$url" "$base_domain"
    fi
}

# Resolve an ssh target/alias to its configured HostName (IP or domain).
ssh_resolved_host() {
    ssh -G "$1" 2>/dev/null | awk '/^hostname /{print $2; exit}'
}

# Bounded TCP connect test (never hangs on a filtered port). port_open <host> <port> [timeout]
port_open() {
    local host="$1" port="$2" to="${3:-5}" pid i
    ( exec 3<>"/dev/tcp/${host}/${port}" ) 2>/dev/null &
    pid=$!
    for (( i=0; i < to*10; i++ )); do
        kill -0 "$pid" 2>/dev/null || break    # connect finished (ok or refused)
        sleep 0.1
    done
    if kill -0 "$pid" 2>/dev/null; then         # still running -> timed out
        kill -9 "$pid" 2>/dev/null || true
        wait "$pid" 2>/dev/null || true
        return 1
    fi
    wait "$pid"                                  # propagate connect exit status
}

# Verify the CNC TLS port is reachable from here; loop with a re-check option.
check_cnc_reachable() {
    local url="$1" host port ans
    host="$(url_host "$url")"; port="$(url_port "$url")"; [ -n "$port" ] || port="443"
    while true; do
        log_info "Checking ${host}:${port} reachability (5s timeout)..."
        if port_open "$host" "$port" 5; then
            log_success "${host}:${port} is reachable."
            return 0
        fi
        echo
        log_warn "Could NOT reach ${host}:${port} - a firewall is most likely blocking it."
        echo "  Add these INBOUND rules on the CNC's firewall, INCLUDING any CLOUD"
        echo "  firewall (e.g. DigitalOcean -> Networking -> Firewalls):"
        echo "      ${port}/tcp    headscale control plane + DERP"
        echo "      3478/udp       STUN (NAT traversal)"
        echo "      41641/udp      tailscale direct connections"
        echo
        if ! read -r -p "[r] re-check (default)   [c] continue anyway   [a] abort: " ans </dev/tty 2>/dev/null; then
            log_warn "No interactive terminal; continuing without a verified check."
            return 0
        fi
        case "${ans:-r}" in
            c|C) log_warn "Continuing without verified reachability."; return 0 ;;
            a|A) die "Aborted. Open the firewall, then re-run." ;;
            *)   ;;  # anything else (incl. empty / 'r') -> re-check
        esac
    done
}

cnc_init_remote() {
    local host="$1" url="$2" port="$3" sshflag scpflag self configured=0
    have ssh || die "ssh not found"; have scp || die "scp not found"
    sshflag="$([ -n "$port" ] && echo "-p $port" || true)"
    scpflag="$([ -n "$port" ] && echo "-P $port" || true)"

    log_info "Checking SSH access to $host..."
    # shellcheck disable=SC2086
    ssh -o ConnectTimeout=10 $sshflag "$host" true || die "Cannot SSH to $host"

    # Only prefix sudo when the remote login user is not root (avoids noise + works for non-root admins).
    local rsudo="sudo "
    # shellcheck disable=SC2086
    if ssh $sshflag "$host" 'test "$(id -u)" = 0' 2>/dev/null; then rsudo=""; fi

    # shellcheck disable=SC2086
    if ssh $sshflag "$host" 'test -f /etc/headscale/config.yaml && systemctl is-active --quiet headscale' 2>/dev/null; then
        configured=1
    fi

    # Determine the server URL: explicit --url, else the remote's existing one,
    # else derive an IP from your SSH config (HostName) + default TLS port.
    if [ -z "$url" ]; then
        if [ "$configured" = 1 ]; then
            # shellcheck disable=SC2086
            url="$(ssh $sshflag "$host" "${rsudo}sed -n 's/^server_url:[[:space:]]*//p' /etc/headscale/config.yaml 2>/dev/null | head -n1" | tr -d '\r')"
        fi
        if [ -z "$url" ]; then
            local ip; ip="$(ssh_resolved_host "$host")"
            [ -n "$ip" ] || die "Could not resolve an address for '$host'; pass --url https://<ip>:${HS_TLS_PORT_DEFAULT}"
            url="https://${ip}:${HS_TLS_PORT_DEFAULT}"
            log_info "No --url given; using ${url} (resolved from your SSH config for '$host')."
        fi
    fi
    # Normalise an IP CNC without a port so the saved link matches the listener.
    if [ "${url%%://*}" = "https" ]; then
        local uh up; uh="$(url_host "$url")"; up="$(url_port "$url")"
        if is_ip "$uh" && [ -z "$up" ]; then url="https://${uh}:${HS_TLS_PORT_DEFAULT}"; fi
    fi

    if [ "$configured" = 1 ]; then
        log_info "CNC already configured on $host; skipping install."
    else
        log_info "Copying connector to $host and running cnc-init..."
        self="$(self_path)"
        # shellcheck disable=SC2086
        scp $scpflag "$self" "$host:/tmp/connector.$$" >/dev/null
        # shellcheck disable=SC2086
        ssh $sshflag "$host" "${rsudo}install -m 0755 /tmp/connector.$$ ${CONNECTOR_BIN} && ${rsudo}ln -sf ${CONNECTOR_BIN} ${CON_BIN} && rm -f /tmp/connector.$$"
        # shellcheck disable=SC2086
        ssh -t $sshflag "$host" "${rsudo}${CONNECTOR_BIN} cnc-init --url '$url'" || die "Remote cnc-init failed"
    fi

    save_cnc_link "$host" "$url" "$port"
    log_success "Linked to CNC $host (this machine is now a manager)."

    check_cnc_reachable "$url"

    echo
    echo "Also register THIS local machine (the one you're running connector on)"
    echo "as a tailnet node?"
    echo "  [1] provider (others can reach/SSH it)   [2] consumer (it reaches providers)"
    echo "  enter '1 2' for both, or [s] to skip"
    local choice; read -r -p "Choose: " choice || choice="s"
    local reg_roles=""
    case "$(echo "$choice" | tr -d ' ')" in
        1)        reg_roles="provider" ;;
        2)        reg_roles="consumer" ;;
        12|21)    reg_roles="provider,consumer" ;;
        ''|s|S)   reg_roles="" ;;
        *) log_warn "Unrecognised choice; skipping." ;;
    esac
    if [ -n "$reg_roles" ]; then
        local key; key="$(mint_key "$reg_roles")"
        cmd_register "$reg_roles" "$url" --authkey "$key" --yes
    else
        log_info "Skipped. Invite machines later with: connector invite"
    fi
}

cmd_link() {
    local host="" url="" port="" sshflag
    while [ $# -gt 0 ]; do
        case "$1" in
            --url)     url="$2"; shift 2 ;;
            -p|--port) port="$2"; shift 2 ;;
            -*) die "Unknown option: $1" ;;
            *) [ -z "$host" ] && host="$1" || die "Unexpected argument: $1"; shift ;;
        esac
    done
    [ -n "$host" ] && [ -n "$url" ] || die "Usage: connector link <user@host> --url https://vpn.example.com [-p port]"
    sshflag="$([ -n "$port" ] && echo "-p $port" || true)"
    log_info "Verifying CNC at $host..."
    # shellcheck disable=SC2086
    ssh -o ConnectTimeout=10 $sshflag "$host" 'test -f /etc/headscale/config.yaml' \
        || die "$host is not a configured CNC (no /etc/headscale/config.yaml)"
    save_cnc_link "$host" "$url" "$port"
    log_success "Linked to CNC $host. This machine is now a manager."
    echo "Try: connector list"
}

# Push this machine's connector to the linked CNC and install it. Returns 0/1.
cnc_update_push() {
    load_cnc_link
    local self sshflag scpflag rsudo="sudo " lsum rsum
    self="$(self_path)"
    sshflag="$([ -n "${CNC_PORT:-}" ] && echo "-p $CNC_PORT" || true)"
    scpflag="$([ -n "${CNC_PORT:-}" ] && echo "-P $CNC_PORT" || true)"
    [ "${CNC_USER:-}" = "root" ] && rsudo=""

    log_info "-> CNC ${CNC_SSH} (${CONNECTOR_BIN})"
    # shellcheck disable=SC2086
    scp $scpflag "$self" "$CNC_SSH:/tmp/connector.$$" >/dev/null 2>&1 || { log_warn "   copy to CNC failed."; return 1; }
    # shellcheck disable=SC2086
    ssh $sshflag "$CNC_SSH" "${rsudo}install -m 0755 /tmp/connector.$$ ${CONNECTOR_BIN} && ${rsudo}ln -sf ${CONNECTOR_BIN} ${CON_BIN} && rm -f /tmp/connector.$$" \
        || { log_warn "   install on CNC failed."; return 1; }

    lsum="$(file_sha256 "$self")"
    # shellcheck disable=SC2086
    rsum="$(ssh $sshflag "$CNC_SSH" "sha256sum ${CONNECTOR_BIN} 2>/dev/null || shasum -a 256 ${CONNECTOR_BIN} 2>/dev/null" | awk '{print $1}' | tr -d '\r')"
    if [ -n "$lsum" ] && [ "$lsum" = "$rsum" ]; then
        log_success "   updated + verified (sha256 ${lsum:0:12}...)"
    else
        log_warn "   installed, but checksum unverified (local=${lsum:-?} cnc=${rsum:-?})."
    fi
}

# Push this machine's connector to a provider node over Tailscale SSH. Returns 0/1.
provider_update_push() {
    local name="$1" user self
    user="$(id -un)"; self="$(self_path)"
    log_info "-> provider ${name} (ssh ${user}@${name})"
    scp -o ConnectTimeout=10 "$self" "${user}@${name}:/tmp/connector.$$" >/dev/null 2>&1 \
        || { log_warn "   copy failed (online + SSH-reachable?)."; return 1; }
    ssh -t -o ConnectTimeout=10 "${user}@${name}" \
        "sudo install -m 0755 /tmp/connector.$$ ${CONNECTOR_BIN} && sudo ln -sf ${CONNECTOR_BIN} ${CON_BIN} && rm -f /tmp/connector.$$" \
        || { log_warn "   remote install failed (sudo rights?)."; return 1; }
    log_success "   updated."
}

# Push this machine's connector script to the linked CNC and install it there.
cmd_cnc_update() {
    is_manager || die "No CNC linked. Run this from a manager (set up via 'connector cnc-init' or 'connector link')."
    have ssh || die "ssh not found"; have scp || die "scp not found"
    cnc_update_push
}

# Print provider node names (TAB online-flag) from the CNC's headscale.
provider_nodes() {
    local json; json="$(hs nodes list -o json 2>/dev/null)" || return 1
    have jq || return 1
    printf '%s' "$json" | jq -r '.[]
        | select((.tags // []) | index("tag:provider"))
        | "\(.given_name)\t\(.online)"' 2>/dev/null
}

# Update connector everywhere: the CNC and (optionally) provider nodes.
cmd_propagate_update() {
    is_manager || die "Run from a manager (linked via 'connector cnc-init' or 'connector link')."
    have ssh || die "ssh not found"; have scp || die "scp not found"
    load_cnc_link

    local -a names=() kinds=()
    names+=("$CNC_SSH"); kinds+=("cnc")
    local nm on
    while IFS="$(printf '\t')" read -r nm on; do
        [ -n "$nm" ] || continue
        names+=("$nm"); kinds+=("provider:$on")
    done < <(provider_nodes 2>/dev/null || true)

    echo "Update connector on which targets?"
    local i label
    for i in "${!names[@]}"; do
        case "${kinds[$i]}" in
            cnc)            label="CNC          (${names[$i]})" ;;
            provider:true)  label="provider     ${names[$i]} (online)" ;;
            provider:false) label="provider     ${names[$i]} (offline - may be unreachable)" ;;
            *)              label="${names[$i]}" ;;
        esac
        printf "  [%d] %s\n" "$((i+1))" "$label"
    done
    echo "  [a] all of the above"

    local opts="A"
    for i in "${!names[@]}"; do opts+="/$((i+1))"; done
    local sel="a"
    if [ "${ASSUME_YES:-0}" != "1" ]; then
        read -r -p "Select [${opts}]: " sel </dev/tty || sel="a"
    fi

    local -a chosen=()
    if [ -z "$sel" ] || printf '%s' " $sel " | grep -qiE ' (a|all|0) '; then
        for i in "${!names[@]}"; do chosen+=("$i"); done
    else
        local tok
        for tok in $sel; do
            case "$tok" in
                ''|*[!0-9]*) continue ;;
                *) [ "$tok" -ge 1 ] && [ "$tok" -le "${#names[@]}" ] && chosen+=("$((tok-1))") ;;
            esac
        done
    fi
    [ "${#chosen[@]}" -gt 0 ] || die "Nothing selected."

    echo
    local idx ok=0 fail=0
    for idx in "${chosen[@]}"; do
        case "${kinds[$idx]}" in
            cnc)         cnc_update_push && ok=$((ok+1)) || fail=$((fail+1)) ;;
            provider:*)  provider_update_push "${names[$idx]}" && ok=$((ok+1)) || fail=$((fail+1)) ;;
        esac
    done
    echo
    if [ "$fail" -eq 0 ]; then log_success "propagate-update complete: ${ok} updated."
    else log_warn "propagate-update finished: ${ok} updated, ${fail} failed."; fi
}

# --- Invite ------------------------------------------------------------------
hs_user_id() {
    local out
    out="$(hs users list --output json 2>/dev/null)" || return 1
    if have jq; then
        printf '%s' "$out" | jq -r --arg n "$HEADSCALE_USER" \
            'first(.[] | select(.name==$n) | .id) // empty' 2>/dev/null | head -n1
        return 0
    fi
    # Fallback for pretty-printed JSON: each user object lists "id" then "name".
    printf '%s' "$out" | tr '\n\t' '  ' | sed 's/  */ /g' \
        | grep -o "\"id\": *[0-9]* *, *\"name\": *\"$HEADSCALE_USER\"" \
        | sed -n 's/.*"id": *\([0-9]*\).*/\1/p' | head -n1
}

# Mint a single-use, short-expiry pre-auth key for a role spec; echo the key.
# headscale's --user takes a numeric user ID, so we always resolve it.
mint_key() {
    local roles tags uid out key
    roles="$(parse_node_roles "$1")"
    [ -n "$roles" ] || die "No roles given for key (expected provider and/or consumer)."
    tags="$(tags_for_roles "$roles")"
    uid="$(hs_user_id 2>/dev/null || true)"
    [ -n "$uid" ] || die "Could not resolve headscale user '$HEADSCALE_USER' on the CNC (is headscale running? try: connector status)"
    out="$(hs preauthkeys create --user "$uid" --tags "$tags" --expiration "$KEY_EXPIRY" --output json 2>/dev/null)" \
        || die "Failed to create pre-auth key on CNC"
    key="$(printf '%s' "$out" | json_str key)"
    [ -n "$key" ] || die "Could not parse pre-auth key from headscale output"
    printf '%s\n' "$key"
}

cmd_invite() {
    is_admin || die "Only a CNC or manager can invite. Link one: connector link <host> --url ..."
    # Roles may be given comma- or space-separated, e.g. 'provider,consumer'.
    # Any non-role token is treated as the new machine's hostname.
    local types=() name="" want_manager=0 tok
    for tok in $(printf '%s ' "$@" | tr ',' ' '); do
        case "$tok" in
            provider) types+=("provider") ;;
            consumer) types+=("consumer") ;;
            both)     types+=("provider"); types+=("consumer") ;;
            manager|controller|commander) want_manager=1 ;;
            *) name="$tok" ;;
        esac
    done

    if [ "${#types[@]}" -eq 0 ] && [ "$want_manager" -eq 0 ]; then
        echo "Invite as (comma-separated for multiple, e.g. provider,consumer):"
        echo "  [1] provider"
        echo "  [2] consumer"
        echo "  [3] manager (commands the CNC over SSH)"
        local sel n
        read -r -p 'Enter roles: ' sel || sel=""
        for n in $(printf '%s' "$sel" | tr ',' ' '); do
            case "$n" in
                1|provider) types+=("provider") ;;
                2|consumer) types+=("consumer") ;;
                3|manager|controller|commander) want_manager=1 ;;
                *) log_warn "Ignoring invalid choice: $n" ;;
            esac
        done
    fi
    [ "${#types[@]}" -eq 0 ] && [ "$want_manager" -eq 0 ] && die "Nothing selected."

    if [ "$want_manager" -eq 1 ]; then
        invite_manager
    fi

    if [ "${#types[@]}" -gt 0 ]; then
        local roles url key hostarg="" pinarg="" fp
        roles="$(parse_node_roles "$(IFS=,; echo "${types[*]}")")"
        url="$(cnc_server_url)"; [ -n "$url" ] || url="<server-url>"
        key="$(mint_key "$roles")"
        [ -n "$name" ] && hostarg=" --hostname $name"
        if is_ip "$(url_host "$url")"; then
            fp="$(cnc_cert_fingerprint 2>/dev/null || true)"
            [ -n "$fp" ] && pinarg=" --ca-sha256 ${fp}"
        fi
        echo
        log_success "Single-use invite created (roles: ${roles}, expires in ${KEY_EXPIRY})."
        echo "Run this on the new machine:"
        echo
        echo "    connector register ${roles} ${url} --authkey ${key}${pinarg}${hostarg}"
        echo
    fi
}

invite_manager() {
    is_admin || die "Only a CNC or manager can invite a manager."
    local url cnc_target pubkey
    url="$(cnc_server_url)"
    if is_manager; then load_cnc_link; cnc_target="$CNC_SSH"; else cnc_target="$(id -un)@$(node_name)"; fi

    echo
    echo "== Invite a manager =="
    echo "A manager commands the CNC over SSH, so its key must be authorized"
    echo "on the CNC admin account (${cnc_target})."
    echo "On the NEW manager, run 'connector manager-key' and paste its output here."
    echo
    read -r -p "Paste SSH public key: " pubkey || true
    [ -n "$pubkey" ] || die "No key provided."
    case "$pubkey" in
        ssh-*|ecdsa-*|sk-*) ;;
        *) die "That does not look like an SSH public key." ;;
    esac
    authorize_manager "$pubkey"
    log_success "Authorized the new manager's key on the CNC admin account."
    echo
    echo "Tell them to run:"
    echo "    connector link ${cnc_target} --url ${url}${CNC_PORT:+ -p $CNC_PORT}"
}

# Append a public key to the CNC admin account's authorized_keys.
authorize_manager() {
    local pubkey="$1"
    if is_cnc; then
        mkdir -p "$HOME/.ssh"; chmod 700 "$HOME/.ssh"
        printf '%s\n' "$pubkey" >> "$HOME/.ssh/authorized_keys"
        chmod 600 "$HOME/.ssh/authorized_keys"
    else
        load_cnc_link
        printf '%s\n' "$pubkey" | ssh_cnc 'umask 077; mkdir -p "$HOME/.ssh"; cat >> "$HOME/.ssh/authorized_keys"'
    fi
}

cmd_manager_key() {
    local k key=""
    for k in "$HOME/.ssh/id_ed25519.pub" "$HOME/.ssh/id_ecdsa.pub" "$HOME/.ssh/id_rsa.pub"; do
        [ -f "$k" ] && { key="$k"; break; }
    done
    if [ -z "$key" ]; then
        log_info "No SSH key found; generating an ed25519 key..."
        ssh-keygen -t ed25519 -N "" -f "$HOME/.ssh/id_ed25519" -C "connector-manager@$(node_name)" >/dev/null
        key="$HOME/.ssh/id_ed25519.pub"
    fi
    echo "# Hand this public key to a CNC/manager running 'connector invite' -> manager:"
    cat "$key"
}

# --- Register (join the tailnet) --------------------------------------------
is_wsl()        { grep -qiE "(microsoft|wsl)" /proc/version 2>/dev/null || [ -n "${WSL_DISTRO_NAME:-}" ]; }
systemd_active() { [ -d /run/systemd/system ]; }

install_tailscale() {
    have tailscale && return 0
    log_info "Installing tailscale..."
    # Arch mirrors keep only the newest build, so a stale local pacman DB makes
    # the upstream installer request a 404'd version. Refresh it first.
    # (apt-based installs are refreshed by the upstream script itself.)
    if have pacman; then
        log_info "Refreshing pacman database (Arch)..."
        as_root pacman -Sy --noconfirm >/dev/null 2>&1 || true
    fi
    curl -fsSL "$TS_INSTALL_URL" | sh
    have tailscale || die "tailscale installation failed. On Arch, run 'sudo pacman -Syu' then re-run register."
}

install_tailscale_macos_app() {
    [ -x "$TS_MAC_APP_CLI" ] && return 0
    if have brew; then
        log_info "Installing the Tailscale GUI app (Homebrew cask)..."
        brew install --cask tailscale \
            || die "brew install --cask tailscale failed; install from https://tailscale.com/download/mac"
    else
        die "Install the Tailscale app from https://tailscale.com/download/mac (or install Homebrew), then re-run."
    fi
    open -a Tailscale 2>/dev/null || true
    log_warn "Launched Tailscale.app - if macOS prompts, allow its VPN/system extension, then re-run register."
}

install_tailscale_macos_oss() {
    have tailscale && return 0
    have brew || die "Homebrew is required for open-source tailscaled (https://brew.sh), or choose the app."
    log_info "Installing open-source tailscaled (Homebrew)..."
    brew install tailscale || die "brew install tailscale failed"
    log_info "Starting tailscaled as a service..."
    sudo brew services start tailscale >/dev/null 2>&1 || brew services start tailscale >/dev/null 2>&1 \
        || log_warn "Could not auto-start tailscaled; run: sudo brew services start tailscale"
}

# Choose (installing if needed) a macOS tailscale CLI. Prints the path on stdout;
# ALL prompts/messages go to stderr so the captured stdout is only the path.
# $2 (needs_ssh): 1 when the roles include provider. The sandboxed GUI app
# cannot host Tailscale SSH, so a provider must use open-source tailscaled.
macos_tailscale_cli() {
    local variant="$1" needs_ssh="${2:-0}" app="$TS_MAC_APP_CLI" oss have_app=0 have_oss=0 c p ans
    [ -x "$app" ] && have_app=1
    oss="$(command -v tailscale 2>/dev/null || true)"
    if [ -z "$oss" ]; then
        for p in /opt/homebrew/bin/tailscale /usr/local/bin/tailscale; do
            [ -x "$p" ] && { oss="$p"; break; }
        done
    fi
    [ -n "$oss" ] && have_oss=1
    case "$variant" in
        app) [ "$needs_ssh" = 1 ] && log_warn "The GUI app can't host Tailscale SSH; this Mac won't be a provider." >&2
             install_tailscale_macos_app >&2; printf '%s\n' "$app"; return 0 ;;
        oss) install_tailscale_macos_oss >&2; command -v tailscale; return 0 ;;
        "")  ;;
        *)   echo "Unknown --tailscale variant: $variant (use 'app' or 'oss')" >&2; return 1 ;;
    esac

    # A provider must host Tailscale SSH -> only open-source tailscaled works.
    if [ "$needs_ssh" = 1 ]; then
        if [ "$have_oss" = 1 ]; then
            log_info "Using open-source tailscaled (required to be a provider on macOS)." >&2
            printf '%s\n' "$oss"; return 0
        fi
        if [ "$have_app" = 1 ]; then
            log_warn "Only the Tailscale GUI app is installed; it CANNOT be a provider (no Tailscale SSH)." >&2
            read -r -p "Install open-source tailscaled so this Mac can be a provider? [Y/n]: " ans </dev/tty || ans=y
            case "${ans:-y}" in
                [nN]*) log_warn "Continuing with the GUI app: it joins the tailnet but is NOT a provider." >&2
                       printf '%s\n' "$app"; return 0 ;;
                *)     install_tailscale_macos_oss >&2; command -v tailscale; return 0 ;;
            esac
        fi
        { echo "Tailscale is not installed. A provider needs Tailscale SSH:"
          echo "  [1] GUI app                 - CANNOT be a provider (no Tailscale SSH)"
          echo "  [2] open-source tailscaled  - recommended (hosts SSH)"; } >&2
        read -r -p "Install [1/2] (default 2): " c </dev/tty || c=2
        case "${c:-2}" in
            1) install_tailscale_macos_app >&2; printf '%s\n' "$app" ;;
            *) install_tailscale_macos_oss >&2; command -v tailscale ;;
        esac
        return 0
    fi

    # Consumer (no SSH server needed): the GUI app is fine.
    if [ "$have_app" = 1 ] && [ "$have_oss" = 0 ]; then printf '%s\n' "$app"; return 0; fi
    if [ "$have_oss" = 1 ] && [ "$have_app" = 0 ]; then printf '%s\n' "$oss"; return 0; fi
    if [ "$have_app" = 1 ] && [ "$have_oss" = 1 ]; then
        { echo "Two Tailscale installs found:"
          echo "  [1] GUI app    ($app)"
          echo "  [2] tailscaled ($oss)"; } >&2
        read -r -p "Use which? [1/2]: " c </dev/tty || c=1
        case "$c" in 2) printf '%s\n' "$oss" ;; *) printf '%s\n' "$app" ;; esac
        return 0
    fi
    { echo "Tailscale is not installed. Install which variant?"
      echo "  [1] GUI app (Homebrew cask / tailscale.com download)"
      echo "  [2] open-source tailscaled (Homebrew, CLI only)"; } >&2
    read -r -p "Install [1/2]: " c </dev/tty || c=1
    case "$c" in
        2) install_tailscale_macos_oss >&2; command -v tailscale ;;
        *) install_tailscale_macos_app >&2; printf '%s\n' "$app" ;;
    esac
}

# Print the post-join summary. register_summary <roles-csv> <cli> <hostname>
register_summary() {
    local roles="$1" cli="$2" hostname="$3" ts_ip ts_name
    ts_ip="$("$cli" ip -4 2>/dev/null | head -n1 || true)"
    ts_name="$("$cli" status --json 2>/dev/null | json_str DNSName)"; ts_name="${ts_name%.}"
    [ -n "$ts_name" ] || ts_name="$hostname"
    echo
    log_success "Connected as ${roles}."
    [ -n "$ts_ip" ] && echo "  Tailnet IP: $ts_ip"
    echo "  MagicDNS:   $ts_name"
    role_has "$roles" provider && echo "  Others reach you via:  ssh <user>@${ts_name}"
    role_has "$roles" consumer && echo "  Reach a provider via:  connector hop <provider-name>"
    role_has "$roles" consumer && echo "  Persistent tmux shell: connector hop -t <provider-name>"
}

register_macos() {
    local roles="$1" url="$2" key="$3" hostname="$4" variant="$5" cli needs_ssh=0
    [ -n "$hostname" ] || hostname="$(node_name)"
    # Providers must host Tailscale SSH, which the sandboxed GUI app can't do;
    # let the CLI chooser steer to open-source tailscaled in that case.
    role_has "$roles" provider && needs_ssh=1
    cli="$(macos_tailscale_cli "$variant" "$needs_ssh")" || die "Could not determine a tailscale CLI."
    [ -n "$cli" ] || die "tailscale CLI not found after install."

    local tags ssh_flag=""
    tags="$(tags_for_roles "$roles")"
    role_has "$roles" provider && ssh_flag="--ssh"

    # GUI app talks to a per-user daemon (no sudo); oss tailscaled needs root.
    local -a runner_cmd
    if [ "$cli" = "$TS_MAC_APP_CLI" ]; then runner_cmd=("$cli"); else runner_cmd=(sudo "$cli"); fi

    # The sandboxed macOS GUI app cannot run the Tailscale SSH *server* ("does not
    # run in sandboxed Tailscale GUI builds"), which otherwise hard-fails 'up'.
    # Drop --ssh so registration succeeds; to host SSH as a provider on macOS, use
    # the open-source tailscaled instead (--tailscale oss).
    if [ -n "$ssh_flag" ] && [ "$cli" = "$TS_MAC_APP_CLI" ]; then
        log_warn "The Tailscale GUI app can't host Tailscale SSH (sandboxed build)."
        log_warn "Registering without --ssh: this Mac joins the tailnet but won't accept"
        log_warn "incoming 'connector hop'. To host SSH on macOS, re-run with --tailscale oss."
        ssh_flag=""
    fi

    log_info "Bringing up tailscale on macOS (roles: $roles, hostname: ${hostname:-auto})..."
    # --reset makes register declarative: apply exactly these flags and ignore
    # stale prefs from earlier attempts (tailscale otherwise refuses to change
    # settings without re-stating every non-default flag).
    # An auth key already carries its tags (forced tags). headscale rejects a
    # user-scoped key combined with --advertise-tags, so only advertise the tags
    # for interactive (keyless) registration where the admin owns them.
    local up_args=(up --reset --login-server "$url" --accept-dns=true)
    [ -n "$hostname" ] && up_args+=(--hostname "$hostname")
    [ -n "$ssh_flag" ] && up_args+=("$ssh_flag")
    if [ -n "$key" ]; then
        up_args+=(--authkey "$key")
    else
        up_args+=(--advertise-tags="$tags")
    fi

    if ! "${runner_cmd[@]}" "${up_args[@]}"; then
        log_warn "tailscale up failed."
        log_warn "If a browser login URL appeared, finish there; or ask the admin to run 'connector approve'."
        log_warn "If using the GUI app, ensure it is running and its system extension is approved."
        die "tailscale up did not complete."
    fi
    mkdir -p "$STATE_DIR"; chmod 700 "$STATE_DIR" 2>/dev/null || true
    printf '%s\n' "$roles" > "$ROLE_FILE"
    install_self_local
    register_summary "$roles" "$cli" "$hostname"
}

# Consent-gated, idempotent WSL systemd enablement. Returns non-zero to abort.
ensure_wsl_systemd() {
    is_wsl || return 0
    systemd_active && return 0
    if grep -qs "systemd=true" /etc/wsl.conf 2>/dev/null; then
        log_warn "systemd is enabled in /etc/wsl.conf but not active yet."
        log_warn "Run 'wsl --shutdown' in Windows, reopen this distro, then re-run register."
        return 1
    fi
    log_warn "tailscale needs systemd, which is not enabled in this WSL distro."
    confirm "Enable systemd in /etc/wsl.conf now?" || { log_error "Cannot continue without systemd."; return 1; }
    as_root bash -c 'touch /etc/wsl.conf
if ! grep -q "^\[boot\]" /etc/wsl.conf; then
    printf "\n[boot]\nsystemd=true\n" >> /etc/wsl.conf
elif ! grep -q "systemd=true" /etc/wsl.conf; then
    sed -i "/^\[boot\]/a systemd=true" /etc/wsl.conf
fi'
    log_success "Enabled systemd in /etc/wsl.conf."
    log_warn "Now run 'wsl --shutdown' in Windows PowerShell, reopen this distro, then re-run your connector register command."
    return 1
}

maybe_fix_wsl_mtu() {
    is_wsl || return 0
    have ip || return 0
    local mtu
    mtu="$(ip link show tailscale0 2>/dev/null | sed -n 's/.* mtu \([0-9]\+\).*/\1/p' | head -n1)"
    if [ -n "$mtu" ] && [ "$mtu" -gt "$WSL_MTU" ]; then
        log_info "Pinning tailscale0 MTU to ${WSL_MTU} (WSL large-packet fix)..."
        as_root ip link set tailscale0 mtu "$WSL_MTU" 2>/dev/null || true
    fi
}

# Install the running connector to CONNECTOR_BIN and create the 'con' shortcut,
# so the node has 'connector'/'con' on PATH after joining. Never fatal.
install_self_local() {
    local self dir; self="$(self_path)"; dir="${CONNECTOR_BIN%/*}"
    [ -n "$self" ] && [ -f "$self" ] || return 0
    as_root mkdir -p "$dir" 2>/dev/null || true
    if [ "$self" != "$CONNECTOR_BIN" ]; then
        as_root install -m 0755 "$self" "$CONNECTOR_BIN" 2>/dev/null \
            || { log_warn "Could not install 'connector' to ${dir} (need sudo?); skipping."; return 0; }
    fi
    as_root ln -sf "$CONNECTOR_BIN" "$CON_BIN" 2>/dev/null || true
    log_success "Installed 'connector' + 'con' to ${dir}."
}

cmd_register() {
    local roles
    roles="$(parse_node_roles "${1:-}")"
    [ -n "$roles" ] || die "Usage: connector register <provider|consumer|provider,consumer> <url> [--authkey KEY] [--ca-sha256 FP] [--hostname N] [--tailscale app|oss] [--yes]"
    shift || true
    local url="" key="" hostname="" pin="" ts_variant=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --authkey)   key="$2"; shift 2 ;;
            --hostname)  hostname="$2"; shift 2 ;;
            --ca-sha256) pin="$(printf '%s' "$2" | tr 'A-F' 'a-f' | tr -d ': ')"; shift 2 ;;
            --tailscale) ts_variant="$2"; shift 2 ;;
            --yes|-y)    ASSUME_YES=1; shift ;;
            -*) die "Unknown option: $1" ;;
            *) [ -z "$url" ] && url="$1" || die "Unexpected argument: $1"; shift ;;
        esac
    done
    [ -n "$url" ] || die "Usage: connector register <provider|consumer|provider,consumer> <url> [--authkey KEY]"

    # On Linux, make sure the join flow's tools are present (prompt to install).
    [ "$(os_kind)" = "linux" ] && ensure_deps curl openssl

    # Trust the CNC's self-signed cert (only for IP CNCs; no-op for domain CNCs).
    establish_cnc_trust "$url" "$pin"

    if [ "$(os_kind)" = "macos" ]; then
        register_macos "$roles" "$url" "$key" "$hostname" "$ts_variant"
        return $?
    fi

    ensure_wsl_systemd || return 0
    install_tailscale
    # tailscaled caches the system CA pool at startup; if it is already running,
    # restart it so a freshly-trusted CNC cert is picked up before we connect
    # (otherwise the control-plane TLS handshake hangs on a self-signed CNC).
    if [ "${url%%://*}" = "https" ] && is_ip "$(url_host "$url")" \
        && have systemctl && systemctl is-active --quiet tailscaled 2>/dev/null; then
        log_info "Restarting tailscaled to load the CNC certificate..."
        as_root systemctl restart tailscaled 2>/dev/null || true
        sleep 1
    fi
    [ -n "$hostname" ] || hostname="$(node_name)"

    local tags ssh_flag=""
    tags="$(tags_for_roles "$roles")"
    role_has "$roles" provider && ssh_flag="--ssh"

    log_info "Bringing up tailscale (roles: $roles, hostname: ${hostname:-auto})..."
    # --reset makes register declarative: apply exactly these flags and ignore
    # stale prefs from earlier attempts (tailscale otherwise refuses to change
    # settings without re-stating every non-default flag).
    # An auth key already carries its tags (forced tags). headscale rejects a
    # user-scoped key combined with --advertise-tags, so only advertise the tags
    # for interactive (keyless) registration where the admin owns them.
    local up_args=(--reset --login-server "$url" --accept-dns=true)
    [ -n "$hostname" ] && up_args+=(--hostname "$hostname")
    [ -n "$ssh_flag" ] && up_args+=("$ssh_flag")
    if [ -n "$key" ]; then
        up_args+=(--authkey "$key")
    else
        up_args+=(--advertise-tags="$tags")
    fi

    if ! as_root tailscale up "${up_args[@]}"; then
        if [ -z "$key" ]; then
            log_warn "No --authkey supplied; tailscale printed a login URL above."
            log_warn "Ask the CNC admin to approve it:  connector approve"
        fi
        die "tailscale up did not complete."
    fi

    mkdir -p "$STATE_DIR"; chmod 700 "$STATE_DIR" 2>/dev/null || true
    printf '%s\n' "$roles" > "$ROLE_FILE"
    maybe_fix_wsl_mtu
    install_self_local
    register_summary "$roles" "tailscale" "$hostname"
}

# --- Admin: list / approve / revoke -----------------------------------------
cmd_list() {
    is_admin || die "Only a CNC or manager can list nodes."
    local rows; rows="$(hs_nodes_tsv 2>/dev/null || true)"
    if [ -n "$rows" ]; then
        print_node_table "$rows"
    else
        hs nodes list   # fallback (no jq, or unexpected output)
    fi
}

approve_routes() {
    local id="$1"
    # Route-approval CLI differs across headscale versions; best-effort, never fatal.
    hs nodes approve-routes --identifier "$id" --routes "" >/dev/null 2>&1 \
        || hs routes enable --identifier "$id" >/dev/null 2>&1 \
        || true
}

cmd_approve() {
    is_admin || die "Only a CNC or manager can approve."
    local node="${1:-}" type="${2:-}"
    if [ -z "$node" ]; then
        echo "Nodes:"
        hs nodes list
        echo
        echo "Tag/approve a node that joined without a key:"
        echo "    connector approve <node-name|id> <provider|consumer|provider,consumer>"
        echo
        echo "(Simpler: 'connector invite' issues a single-use key so no approval step is needed.)"
        return 0
    fi
    local id; id="$(resolve_node_id "$node")" || die "Node not found: $node"
    approve_routes "$id"
    if [ -n "$type" ]; then
        local roles tags
        roles="$(parse_node_roles "$type")"
        [ -n "$roles" ] || die "type must be provider, consumer, or provider,consumer"
        tags="$(tags_for_roles "$roles")"
        hs nodes tag --identifier "$id" --tags "$tags"
        log_success "Tagged node $node as $roles."
    fi
    log_success "Approved node $node (id $id)."
}

cmd_revoke() {
    is_admin || die "Only a CNC or manager can revoke nodes."
    local node="${1:-}"
    [ -n "$node" ] || die "Usage: connector revoke <node-name|node-id>"
    local id; id="$(resolve_node_id "$node")" || die "Node not found: $node"
    log_warn "Revoking node $node (id $id)..."
    hs nodes delete --identifier "$id" --force 2>/dev/null || hs nodes delete --identifier "$id"
    log_success "Revoked $node."
}

# --- Status / whoami ---------------------------------------------------------
cmd_status() {
    echo "Roles: $(current_roles)"
    if is_manager; then load_cnc_link; echo "Linked CNC: $CNC_SSH ($CNC_URL)"; fi
    echo
    if is_cnc; then
        if systemctl is-active --quiet headscale 2>/dev/null; then
            log_success "headscale service is running"
        else
            log_warn "headscale service is not running"
        fi
        echo
        as_root headscale nodes list 2>/dev/null || true
        return 0
    fi
    if have tailscale; then
        tailscale status || log_warn "tailscale not connected"
    else
        log_warn "tailscale is not installed on this machine."
    fi
}

cmd_whoami() {
    echo "Roles: $(current_roles)"
    if is_manager; then load_cnc_link; echo "Linked CNC: $CNC_SSH"; echo "Server URL: $CNC_URL"; fi
    if is_cnc; then echo "Server URL: $(cnc_server_url)"; fi
    if is_node; then
        local ip; ip="$(tailscale ip -4 2>/dev/null | head -n1 || true)"
        [ -n "$ip" ] && echo "Tailnet IP: $ip"
    fi
}

# --- hop / alias -------------------------------------------------------------
# Run the tailscale CLI for this OS (prefer the macOS app's daemon).
ts_cli() {
    if [ "$(os_kind)" = "macos" ] && [ -x "$TS_MAC_APP_CLI" ]; then "$TS_MAC_APP_CLI" "$@"
    else tailscale "$@"; fi
}
have_ts() { { [ "$(os_kind)" = "macos" ] && [ -x "$TS_MAC_APP_CLI" ]; } || have tailscale; }

# jq snippet: derive a role label from a tags array bound as $t.
JQ_ROLE='(if ($t|index("tag:provider")) and ($t|index("tag:consumer")) then "provider,consumer"
          elif ($t|index("tag:provider")) then "provider"
          elif ($t|index("tag:consumer")) then "consumer" else "-" end)'

# This node's view of the tailnet (self + visible peers) as TSV:
#   id <TAB> name <TAB> role <TAB> ip <TAB> online(1/0)   (id is "-" here).
ts_nodes_tsv() {
    have jq || return 1
    ts_cli status --json 2>/dev/null | jq -r "
        ([.Self] + ((.Peer // {}) | to_entries | map(.value)))[]
        | (.Tags // []) as \$t
        | [ \"-\",
            ((.DNSName // (.HostName + \".\")) | sub(\"\\\\.\$\";\"\") | split(\".\")[0]),
            $JQ_ROLE,
            ((.TailscaleIPs // []) | map(select(test(\":\")|not)) | .[0] // \"-\"),
            (if .Online then \"1\" else \"0\" end) ] | @tsv" 2>/dev/null
}

# All tailnet nodes from headscale (admin only) as the same TSV shape.
hs_nodes_tsv() {
    have jq || return 1
    local json; json="$(hs nodes list -o json 2>/dev/null)" || return 1
    [ -n "$json" ] || return 1
    printf '%s' "$json" | jq -r "
        .[] | (.tags // []) as \$t
        | [ (.id|tostring), .given_name, $JQ_ROLE,
            ((.ip_addresses // []) | map(select(test(\":\")|not)) | .[0] // \"-\"),
            (if .online then \"1\" else \"0\" end) ] | @tsv" 2>/dev/null
}

# Render TSV node rows as a clean table, adding ONLINE + CONNECTABLE (relative to
# this machine) columns. A consumer can SSH to online providers; self is never
# connectable. Drops machine/node keys, duplicate name, and expiration.
print_node_table() {
    local rows="$1" self_ip="" me_consumer=0
    [ -n "$rows" ] || { echo "No nodes found."; return 0; }
    is_consumer && me_consumer=1
    have jq && self_ip="$(ts_cli status --json 2>/dev/null | jq -r '(.Self.TailscaleIPs // [])[0] // empty' 2>/dev/null || true)"
    {
        printf 'ID\tNAME\tROLE\tIP\tONLINE\tCONNECTABLE\n'
        local id name role ip online onl conn
        while IFS=$'\t' read -r id name role ip online; do
            [ -n "$name" ] || continue
            [ "$online" = "1" ] && onl="yes" || onl="no"
            if [ -n "$self_ip" ] && [ "$ip" = "$self_ip" ]; then
                conn="no (self)"
            elif [ "$me_consumer" = 1 ] && [ "$online" = "1" ] && role_has "$role" provider; then
                conn="yes"
            else
                conn="no"
            fi
            printf '%s\t%s\t%s\t%s\t%s\t%s\n' "${id:--}" "$name" "$role" "${ip:--}" "$onl" "$conn"
        done <<EOF
$rows
EOF
    } | { if have column; then column -t -s "$(printf '\t')"; else cat; fi; }
}

# List ONLY the hosts this machine can connect to: the CNC (for a manager) and
# online providers a consumer may SSH to. Used by 'help' + arg-less 'hop'/'ssh'.
# Quiet (prints nothing) when there is nothing to connect to.
print_hosts() {
    local out="" n names
    if is_manager; then
        load_cnc_link
        if [ -n "${CNC_SSH:-}" ]; then
            local cnc_name="${CNC_SSH##*@}"   # bare host/alias, e.g. 'nyc'
            out+="  ${cnc_name}  (cnc)"$'\n'
        fi
    fi
    if have_ts && is_consumer && have jq; then
        names="$(ts_cli status --json 2>/dev/null | jq -r '
            (.Peer // {}) | to_entries[] | .value
            | select((.Tags // []) | index("tag:provider"))
            | select(.Online == true)
            | (.DNSName // (.HostName + ".")) | sub("\\.$";"") | split(".")[0]' 2>/dev/null || true)"
        while IFS= read -r n; do [ -n "$n" ] && out+="  $n"$'\n'; done <<EOF
$names
EOF
    fi
    [ -n "$out" ] || return 0
    echo "Hosts you can connect to:"
    printf '%s' "$out"
}

# True if $1 names the linked CNC: the literal 'cnc', the CNC's ssh remote
# (e.g. 'root@1.2.3.4'), or its bare host/alias (e.g. 'nyc').
is_cnc_target() {
    [ "$1" = "cnc" ] && return 0
    is_manager || return 1
    [ -f "$CNC_LINK_FILE" ] || return 1
    load_cnc_link
    [ -n "${CNC_SSH:-}" ] || return 1
    [ "$1" = "$CNC_SSH" ] && return 0
    [ "$1" = "${CNC_SSH##*@}" ] && return 0
    return 1
}

cmd_hop() {
    local tmux=0 tflag="" session=""
    local -a pos=()
    while [ $# -gt 0 ]; do
        case "$1" in
            -t|--tmux)    tmux=1 ;;
            -a|--attach)  tmux=1; tflag="-a" ;;
            -l|--list)    tmux=1; tflag="-l" ;;
            -k|--kill)    tmux=1; tflag="-k" ;;
            -s|--session) tmux=1; session="${2:-}"; shift ;;
            --)           shift; while [ $# -gt 0 ]; do pos+=("$1"); shift; done; break ;;
            -*)           die "Unknown hop option: $1" ;;
            *)            pos+=("$1") ;;
        esac
        shift
    done
    local target="${pos[0]:-}"
    [ "${#pos[@]}" -ge 2 ] && [ -z "$session" ] && session="${pos[1]}"

    if [ -z "$target" ]; then
        print_hosts
        return 0
    fi

    # Resolve a saved alias (name -> user@magicdns-name) on the target token, so
    # 'connector <alias>' and 'connector hop <alias>' behave identically.
    local _aline; _aline="$(alias_lookup "$target" || true)"
    [ -n "$_aline" ] && target="${_aline#*|}"

    # Resolve an ssh target (+ optional port) once, for both CNC and provider hops.
    # The CNC is not a tailnet node: a manager reaches it over its existing admin
    # SSH. Accept the literal 'cnc' or the CNC's ssh remote name (e.g. 'nyc'), so
    # you can use the same name you linked it with.
    local ssh_target="" port=""
    if is_cnc_target "$target"; then
        is_cnc && die "This machine is the CNC."
        is_manager || die "Only a manager can hop to the CNC (link one: connector link ...)."
        load_cnc_link
        [ -n "${CNC_SSH:-}" ] || die "No CNC link found."
        ssh_target="$CNC_SSH"; port="${CNC_PORT:-}"
    elif [[ "$target" == *"@"* ]]; then
        ssh_target="$target"
    else
        ssh_target="$(id -un)@${target}"
    fi

    if [ "$tmux" = 1 ]; then
        hop_tmux "$ssh_target" "$port" "$tflag" "$session"
        return $?
    fi

    local p=""; [ -n "$port" ] && p="-p $port"
    # shellcheck disable=SC2086
    ssh $p "$ssh_target"
}

# SSH to a host and attach/manage a persistent tmux session there. The heavy
# lifting runs on the remote via its own 'connector tmux' worker (connector is
# already installed on every provider/CNC), so dependency install + persistence
# setup reuse that machine's helpers. tflag is '' | '-a' | '-l' | '-k'.
hop_tmux() {
    local ssh_target="$1" port="$2" tflag="$3" session="$4"
    have ssh || die "ssh not found"
    local p=""; [ -n "$port" ] && p="-p $port"

    # The remote needs a connector new enough to define cmd_tmux (older ones
    # would mistake 'tmux' for an implicit hop target and try to SSH onwards).
    # shellcheck disable=SC2086
    if ! ssh $p "$ssh_target" "grep -q '^cmd_tmux()' '$CONNECTOR_BIN' 2>/dev/null"; then
        log_error "'connector' on ${ssh_target} is missing the 'tmux' command (out of date)."
        die "Update it from a manager:  connector propagate-update"
    fi

    # Push our local tmux config so it follows us, without clobbering the remote's
    # own config (the remote layers this copy in via 'tmux -f'). Support both the
    # classic ~/.tmux.conf and the XDG path (~/.config/tmux/tmux.conf). The write
    # path is expanded on the REMOTE (single-quoted) so it honours its $HOME/XDG.
    local lconf="" c
    for c in "$HOME/.tmux.conf" "${XDG_CONFIG_HOME:-$HOME/.config}/tmux/tmux.conf"; do
        [ -f "$c" ] && { lconf="$c"; break; }
    done
    if [ -n "$lconf" ]; then
        # shellcheck disable=SC2086
        ssh $p "$ssh_target" \
            'd="${XDG_CONFIG_HOME:-$HOME/.config}/connector"; mkdir -p "$d" && cat > "$d/tmux.user.conf"' \
            < "$lconf" 2>/dev/null \
            || log_warn "Could not push ${lconf} to ${ssh_target} (continuing)."
    fi

    local rcmd="$CONNECTOR_BIN tmux"
    [ -n "$tflag" ] && rcmd="$rcmd $tflag"
    [ -n "$session" ] && rcmd="$rcmd $(printf '%q' "$session")"
    # shellcheck disable=SC2086
    local rc=0
    ssh -t $p "$ssh_target" "$rcmd" || rc=$?
    flush_notes   # surface any local push warnings now that tmux released the TTY
    return $rc
}

# Clone a tmux plugin repo if absent (idempotent, shallow). Never fatal.
clone_tmux_plugin() {
    local url="$1" dir="$2"
    [ -d "$dir/.git" ] && return 0
    git clone --depth 1 "$url" "$dir" >/dev/null 2>&1 || log_warn "Could not clone ${url}."
}

# Install TPM + tmux-resurrect + tmux-continuum, write the connector-managed
# tmux config (layering your personal config), and wire reboot persistence.
# Idempotent: safe to run on every hop. Runs on the host owning the session.
setup_persistent_tmux() {
    local plugins="$HOME/.tmux/plugins" tpm
    tpm="$plugins/tpm"
    mkdir -p "$STATE_DIR" "$TMUX_RESURRECT_DIR" "$plugins"
    chmod 700 "$STATE_DIR" 2>/dev/null || true

    clone_tmux_plugin https://github.com/tmux-plugins/tpm "$tpm"
    clone_tmux_plugin https://github.com/tmux-plugins/tmux-resurrect "$plugins/tmux-resurrect"
    clone_tmux_plugin https://github.com/tmux-plugins/tmux-continuum "$plugins/tmux-continuum"

    # The host's own personal config (classic or XDG path), used only as a
    # fallback when the client didn't push one. We never modify it.
    local host_conf="" c
    for c in "$HOME/.tmux.conf" "${XDG_CONFIG_HOME:-$HOME/.config}/tmux/tmux.conf"; do
        [ -f "$c" ] && { host_conf="$c"; break; }
    done
    local personal_block
    personal_block="if-shell '[ -f \"$TMUX_USER_CONF\" ]' 'source-file \"$TMUX_USER_CONF\"'"
    if [ -n "$host_conf" ]; then
        personal_block="$personal_block
if-shell '[ ! -f \"$TMUX_USER_CONF\" ] && [ -f \"$host_conf\" ]' 'source-file \"$host_conf\"'"
    fi

    # Rewritten each run so config/path changes propagate. We never touch the
    # host's own config; we only source it as a fallback personal config.
    cat > "$TMUX_CONF" <<EOF
# Managed by connector - do not edit (your tmux edits belong in your own config).
# Layer a personal config: the pushed client copy if present, else this host's own.
$personal_block

# Persistence: tmux-resurrect + tmux-continuum (auto save/restore).
set -g @resurrect-dir '$TMUX_RESURRECT_DIR'
set -g @continuum-restore 'on'
set -g @continuum-save-interval '15'
set -g @continuum-boot 'off'
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-continuum'
run '$tpm/tpm'
EOF
    chmod 600 "$TMUX_CONF" 2>/dev/null || true

    setup_tmux_boot
}

# Reboot persistence via a systemd --user service + linger. Best-effort: on
# non-systemd hosts we keep disconnect-persistence and warn.
setup_tmux_boot() {
    if ! have systemctl || [ ! -d /run/systemd/system ]; then
        log_warn "No systemd here: tmux sessions persist across disconnects but not reboots."
        return 0
    fi
    local tmux_bin unit_dir unit user uid
    tmux_bin="$(command -v tmux)"; user="$(id -un)"; uid="$(id -u)"
    unit_dir="$HOME/.config/systemd/user"; unit="$unit_dir/connector-tmux.service"
    mkdir -p "$unit_dir"
    cat > "$unit" <<EOF
[Unit]
Description=connector persistent tmux server
Documentation=man:tmux(1)
After=network-online.target

[Service]
Type=forking
ExecStart=${tmux_bin} -L ${TMUX_SOCKET} -f ${TMUX_CONF} new-session -d -s main
ExecStop=${tmux_bin} -L ${TMUX_SOCKET} kill-server
KillMode=control-group
Restart=on-failure

[Install]
WantedBy=default.target
EOF
    # Linger first: it starts (and keeps) this user's systemd instance even with
    # no active login, so boot-time restore works AND the user bus exists for the
    # 'systemctl --user' calls below.
    if ! loginctl show-user "$user" 2>/dev/null | grep -q '^Linger=yes'; then
        loginctl enable-linger "$user" >/dev/null 2>&1 \
            || as_root loginctl enable-linger "$user" >/dev/null 2>&1 \
            || log_warn "Could not enable linger; for reboot persistence run: sudo loginctl enable-linger $user"
    fi
    # 'systemctl --user' needs these to reach the user bus; over a non-interactive
    # SSH they're often unset even though linger keeps the user manager running.
    export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$uid}"
    export DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=${XDG_RUNTIME_DIR}/bus}"
    systemctl --user daemon-reload >/dev/null 2>&1 || true
    systemctl --user enable connector-tmux.service >/dev/null 2>&1 \
        || log_warn "Could not enable the systemd user service (sessions still survive disconnects)."
}

# Launch the connector tmux server in the foreground; when it hands the TTY back
# (detach/exit), replay any buffered warnings, then end. Use instead of a bare
# 'exec tmux' so setup notes aren't lost behind tmux's alternate screen.
tmux_exec() {
    local rc=0
    tmux -L "$TMUX_SOCKET" -f "$TMUX_CONF" "$@" || rc=$?
    flush_notes
    exit "$rc"
}

# Populate TMUX_SES_NAMES / TMUX_SES_LABELS with this host's connector sessions.
collect_tmux_sessions() {
    TMUX_SES_NAMES=(); TMUX_SES_LABELS=()
    local name wins att plural
    while IFS='|' read -r name wins att; do
        [ -n "$name" ] || continue
        plural="windows"; [ "$wins" = "1" ] && plural="window"
        TMUX_SES_NAMES+=("$name")
        TMUX_SES_LABELS+=("$name ($wins $plural${att:+, $att})")
    done < <(tmux -L "$TMUX_SOCKET" -f "$TMUX_CONF" ls \
        -F '#{session_name}|#{session_windows}|#{?session_attached,attached,}' 2>/dev/null)
}

# Interactive attach picker. Execs into the chosen/new session; returns (so the
# caller creates the default) when there are no sessions; exits 0 on cancel.
tmux_pick() {
    collect_tmux_sessions
    [ "${#TMUX_SES_NAMES[@]}" -gt 0 ] || return 0
    echo "Sessions on $(node_name):"
    local i
    for i in "${!TMUX_SES_NAMES[@]}"; do
        printf '  [%d] %s\n' "$((i+1))" "${TMUX_SES_LABELS[$i]}"
    done
    echo "  [n] new session"
    echo "  [q] cancel"
    local sel; read -r -p "Select: " sel </dev/tty || sel="q"
    case "$sel" in
        ''|q|Q) exit 0 ;;
        n|N)
            local name; read -r -p "New session name: " name </dev/tty || name=""
            [ -n "$name" ] || name="main"
            tmux_exec new-session -A -s "$name"
            ;;
        *[!0-9]*) die "Invalid selection." ;;
        *)
            { [ "$sel" -ge 1 ] && [ "$sel" -le "${#TMUX_SES_NAMES[@]}" ]; } || die "Invalid selection."
            tmux_exec attach -t "${TMUX_SES_NAMES[$((sel-1))]}"
            ;;
    esac
}

# Kill a session (named, or chosen from a picker) after confirmation.
tmux_kill() {
    local session="$1"
    if [ -z "$session" ]; then
        collect_tmux_sessions
        [ "${#TMUX_SES_NAMES[@]}" -gt 0 ] || { echo "No sessions to kill."; return 0; }
        echo "Sessions on $(node_name):"
        local i
        for i in "${!TMUX_SES_NAMES[@]}"; do
            printf '  [%d] %s\n' "$((i+1))" "${TMUX_SES_LABELS[$i]}"
        done
        echo "  [q] cancel"
        local sel; read -r -p "Kill which? " sel </dev/tty || sel="q"
        case "$sel" in
            ''|q|Q) return 0 ;;
            *[!0-9]*) die "Invalid selection." ;;
            *) { [ "$sel" -ge 1 ] && [ "$sel" -le "${#TMUX_SES_NAMES[@]}" ]; } || die "Invalid selection."
               session="${TMUX_SES_NAMES[$((sel-1))]}" ;;
        esac
    fi
    tmux -L "$TMUX_SOCKET" -f "$TMUX_CONF" has-session -t "$session" 2>/dev/null \
        || die "No tmux session '$session' on $(node_name)."
    confirm "Kill tmux session '$session'?" || { log_info "Cancelled."; return 0; }
    tmux -L "$TMUX_SOCKET" -f "$TMUX_CONF" kill-session -t "$session" \
        && log_success "Killed session '$session'."
}

# Worker that owns the session (runs on the remote via 'hop -t', or locally).
# Ensures tmux + persistence are set up, then attaches/creates/lists/kills.
cmd_tmux() {
    local mode="create" session=""
    local -a pos=()
    while [ $# -gt 0 ]; do
        case "$1" in
            -a|--attach)  mode="attach" ;;
            -l|--list)    mode="list" ;;
            -k|--kill)    mode="kill" ;;
            -s|--session) session="${2:-}"; shift ;;
            -*) die "Unknown tmux option: $1" ;;
            *) pos+=("$1") ;;
        esac
        shift
    done
    [ "${#pos[@]}" -ge 1 ] && [ -z "$session" ] && session="${pos[0]}"

    # Don't nest tmux: if we're already inside a session on THIS machine,
    # attaching/creating would fail ("sessions should be nested with care").
    # When we're inside the connector server, switch within it; else just inform.
    # (list/kill are safe inside tmux, so they're allowed through.)
    if [ -n "${TMUX:-}" ] && [ "$mode" != "list" ] && [ "$mode" != "kill" ]; then
        local _sock="${TMUX%%,*}"           # current session's socket path
        if [ "${_sock##*/}" = "$TMUX_SOCKET" ] && { [ "$mode" != "attach" ] || [ -n "$session" ]; }; then
            local want="${session:-main}"
            if [ "$mode" = "attach" ] && ! tmux -L "$TMUX_SOCKET" has-session -t "$want" 2>/dev/null; then
                log_warn "No tmux session '$want' on $(node_name)."
                die "Create it by dropping -a, e.g.:  connector tmux $want"
            fi
            tmux -L "$TMUX_SOCKET" has-session -t "$want" 2>/dev/null \
                || tmux -L "$TMUX_SOCKET" -f "$TMUX_CONF" new-session -d -s "$want"
            log_info "Already in the connector tmux; switching to '$want'."
            exec tmux -L "$TMUX_SOCKET" switch-client -t "$want"
        fi
        log_warn "Already inside a tmux session on $(node_name); not nesting."
        log_info "Detach first (prefix + d), then re-run your connector tmux command."
        return 0
    fi

    ensure_deps tmux git
    setup_persistent_tmux

    case "$mode" in
        list)
            tmux -L "$TMUX_SOCKET" -f "$TMUX_CONF" ls 2>/dev/null || echo "No sessions."
            return 0
            ;;
        kill)
            tmux_kill "$session"
            return $?
            ;;
        attach)
            # Strict attach: never auto-create a named session.
            if [ -n "$session" ]; then
                if tmux -L "$TMUX_SOCKET" -f "$TMUX_CONF" has-session -t "$session" 2>/dev/null; then
                    tmux_exec attach -t "$session"
                fi
                log_warn "No tmux session '$session' on $(node_name)."
                die "Create it by dropping -a, e.g.:  connector hop -t <host> $session"
            fi
            tmux_pick   # execs on choice; returns here only when no sessions exist
            ;;
    esac

    # default / -s / picker-with-no-sessions: attach-or-create.
    tmux_exec new-session -A -s "${session:-main}"
}

is_reserved() { local n; for n in "${RESERVED_COMMANDS[@]}"; do [ "$1" = "$n" ] && return 0; done; return 1; }

ensure_aliases_file() {
    mkdir -p "$STATE_DIR"; chmod 700 "$STATE_DIR" 2>/dev/null || true
    [ -f "$ALIASES_FILE" ] || {
        printf '# connector aliases\n# format: name|user@magicdns-name\n' > "$ALIASES_FILE"
        chmod 600 "$ALIASES_FILE"
    }
}
alias_lookup() { [ -f "$ALIASES_FILE" ] && grep -E "^$1\|" "$ALIASES_FILE" 2>/dev/null | head -n1; }

cmd_alias() {
    local sub="${1:-list}"
    case "$sub" in
        ""|list|ls)
            ensure_aliases_file
            printf "%-20s %s\n" "NAME" "TARGET"
            local n t c=0
            while IFS='|' read -r n t; do
                [ -z "$n" ] && continue
                [[ "$n" == \#* ]] && continue
                printf "%-20s %s\n" "$n" "$t"; c=$((c+1))
            done < "$ALIASES_FILE"
            [ "$c" -eq 0 ] && echo "(none) - add one: connector alias <name> <user@magicdns-name>"
            ;;
        rm|remove|delete)
            local name="${2:-}"; [ -n "$name" ] || die "Usage: connector alias rm <name>"
            ensure_aliases_file
            local tmp; tmp="$(mktemp)"
            grep -vE "^$name\|" "$ALIASES_FILE" > "$tmp" 2>/dev/null || true
            mv "$tmp" "$ALIASES_FILE"; chmod 600 "$ALIASES_FILE"
            ssh_config_remove_block "$name"
            log_success "Removed alias $name"
            ;;
        *)
            local name="$1" target="${2:-}"
            [ -n "$name" ] && [ -n "$target" ] || die "Usage: connector alias <name> <user@magicdns-name>"
            is_reserved "$name" && die "Alias '$name' conflicts with a built-in command."
            ensure_aliases_file
            local tmp; tmp="$(mktemp)"
            grep -vE "^$name\|" "$ALIASES_FILE" > "$tmp" 2>/dev/null || true
            mv "$tmp" "$ALIASES_FILE"
            printf '%s|%s\n' "$name" "$target" >> "$ALIASES_FILE"; chmod 600 "$ALIASES_FILE"
            log_success "Saved alias $name -> $target   (run: connector $name)"
            if confirm "Add a matching ~/.ssh/config Host entry so 'ssh $name' works?"; then
                ssh_config_add_block "$name" "$target"
            fi
            ;;
    esac
}

ssh_config_add_block() {
    local name="$1" target="$2" user host
    if [[ "$target" == *"@"* ]]; then user="${target%@*}"; host="${target##*@}"; else user="$(id -un)"; host="$target"; fi
    mkdir -p "$(dirname "$SSH_CONFIG_FILE")"; chmod 700 "$(dirname "$SSH_CONFIG_FILE")" 2>/dev/null || true
    touch "$SSH_CONFIG_FILE"; chmod 600 "$SSH_CONFIG_FILE"
    if grep -qF "# BEGIN connector alias $name" "$SSH_CONFIG_FILE" 2>/dev/null; then
        log_warn "$SSH_CONFIG_FILE already has '$name'"; return 0
    fi
    cat >> "$SSH_CONFIG_FILE" <<EOF

# BEGIN connector alias $name
Host $name
    HostName $host
    User $user
# END connector alias $name
EOF
    log_success "Added Host '$name' to $SSH_CONFIG_FILE"
}

ssh_config_remove_block() {
    local name="$1" tmp
    [ -f "$SSH_CONFIG_FILE" ] || return 0
    grep -qF "# BEGIN connector alias $name" "$SSH_CONFIG_FILE" 2>/dev/null || return 0
    tmp="$(mktemp)"
    awk -v m="connector alias $name" '
        $0 == "# BEGIN " m {s=1; next}
        s && $0 == "# END " m {s=0; next}
        !s {print}' "$SSH_CONFIG_FILE" > "$tmp"
    mv "$tmp" "$SSH_CONFIG_FILE"; chmod 600 "$SSH_CONFIG_FILE"
    log_success "Removed Host '$name' from $SSH_CONFIG_FILE"
}

# --- Cleanup -----------------------------------------------------------------
cmd_cleanup() {
    log_warn "This will disconnect this machine from the tailnet."
    confirm "Continue?" || { log_info "Cancelled."; exit 0; }
    local cli=""
    if have tailscale; then cli="tailscale"; elif [ -x "$TS_MAC_APP_CLI" ]; then cli="$TS_MAC_APP_CLI"; fi
    if [ -n "$cli" ]; then
        if [ "$cli" = "$TS_MAC_APP_CLI" ]; then
            "$cli" down 2>/dev/null || true; "$cli" logout 2>/dev/null || true
        else
            as_root "$cli" logout 2>/dev/null || true; as_root "$cli" down 2>/dev/null || true
        fi
    fi
    rm -f "$ROLE_FILE"
    # Remove the trusted self-signed CNC cert, if we installed one.
    if [ -s "$CNC_CA_FILE" ]; then
        local cn; cn="$(openssl x509 -in "$CNC_CA_FILE" -noout -subject 2>/dev/null | sed -n 's/.*CN *= *//p' | head -n1)"
        untrust_cnc_cert "$cn"
        log_info "Removed the trusted CNC certificate."
    fi
    if is_manager && confirm "Also forget the linked CNC?"; then
        rm -f "$CNC_LINK_FILE"; log_success "Forgot CNC link."
    fi
    log_success "Cleanup complete."
}

cmd_cleanup_cnc() {
    is_admin || die "Only a CNC or manager can run cleanup-cnc."
    log_warn "This will delete ALL nodes and stop headscale on the CNC."
    confirm "Continue?" || { log_info "Cancelled."; exit 0; }
    local out ids id
    out="$(hs nodes list --output json 2>/dev/null)" || out=""
    if have jq; then
        ids="$(printf '%s' "$out" | jq -r '.[].id' 2>/dev/null)"
    else
        ids="$(printf '%s' "$out" | tr '\n\t' '  ' | grep -o '"id": *"\{0,1\}[0-9]*' \
             | sed -n 's/.*"id": *"\{0,1\}\([0-9]*\).*/\1/p' | sort -un)"
    fi
    for id in $ids; do
        hs nodes delete --identifier "$id" --force >/dev/null 2>&1 || true
    done
    if is_cnc; then
        as_root systemctl stop headscale 2>/dev/null || true
        as_root systemctl disable headscale 2>/dev/null || true
        as_root rm -rf "$HEADSCALE_CERT_DIR" 2>/dev/null || true
    else
        ssh_cnc "sudo systemctl stop headscale; sudo systemctl disable headscale; sudo rm -rf '$HEADSCALE_CERT_DIR'" 2>/dev/null || true
    fi
    log_success "CNC cleaned up (nodes deleted, headscale stopped)."
    echo
    echo "Migrating from the old WireGuard connector? Tear down leftover state if present:"
    echo "  sudo systemctl disable --now wg-quick@wg-connector"
    echo "  sudo rm -f /etc/wireguard/wg-connector.conf"
    echo "  sudo rm -rf /var/lib/wsl-registry; sudo userdel -r connector 2>/dev/null"
    echo "  and remove any 'Match User connector' blocks from /etc/ssh/sshd_config"
}

